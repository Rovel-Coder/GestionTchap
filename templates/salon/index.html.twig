{% extends 'base.html.twig' %}

{% block title %}Salons — Gestion Tchap{% endblock %}

{% block content %}
<div class="view" x-data="salonView()" x-init="load()">

    {# ── Toolbar ── #}
    <div class="view-toolbar">
        <div class="toolbar-left">
            <span class="view-title">SALONS TCHAP</span>
            <span class="badge" x-text="filtered.length + ' salon' + (filtered.length > 1 ? 's' : '')"></span>
        </div>
        <div class="toolbar-right">
            <div class="salon-filter-chips">
                <button class="salon-filter-btn" :class="{ active: typeFilter === 'Tous' }" @click="typeFilter = 'Tous'">Tous</button>
                <button class="salon-filter-btn" :class="{ active: typeFilter === 'operationnel' }" @click="typeFilter = 'operationnel'">Opérationnels</button>
                <button class="salon-filter-btn" :class="{ active: typeFilter === 'information' }" @click="typeFilter = 'information'">Information</button>
                <button class="salon-filter-btn" :class="{ active: typeFilter === 'crise' }" @click="typeFilter = 'crise'">Crise</button>
                <button class="salon-filter-btn" :class="{ active: typeFilter === 'admin' }" @click="typeFilter = 'admin'">Admin</button>
            </div>
            {% if permissions.canAdmin %}
            <button class="btn-ghost" :class="{ 'btn-active': selectMode }" @click="toggleSelectMode()" title="Mode sélection multiple">
                <i class="fa-solid fa-check-square"></i>
                <span x-show="!selectMode">Sélectionner</span>
                <span x-show="selectMode">Annuler</span>
            </button>
            <button x-show="selectMode && selectedSalons.length > 0" class="btn-danger"
                @click="confirmBulkDelete()"
                x-text="'Supprimer (' + selectedSalons.length + ')'">
            </button>
            {% endif %}
            {% if permissions.canManage %}
            <button class="btn-ghost" :disabled="syncing" @click="syncAllToTchap()" title="Synchroniser tous les salons vers Tchap">
                <i class="fa-solid fa-rotate" :class="{ 'fa-spin': syncing }"></i>
                Synchroniser
            </button>
            <label class="btn-ghost" style="cursor:pointer;display:flex;align-items:center;gap:7px;" title="Importer des salons depuis un CSV"
                @click="importOpen = true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="flex-shrink:0"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Importer CSV
            </label>
            <button class="btn-primary" @click="openModal('create')">
                <i class="fa-solid fa-plus"></i> Créer un salon
            </button>
            {% endif %}
        </div>
    </div>

    {# ── Barre de sélection ── #}
    <div x-show="selectMode" style="display:flex;align-items:center;gap:12px;padding:6px 0;font-size:13px;color:var(--text-secondary);">
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
            <input type="checkbox" :checked="selectedSalons.length === filtered.length && filtered.length > 0"
                :indeterminate="selectedSalons.length > 0 && selectedSalons.length < filtered.length"
                @change="$event.target.checked ? selectAll() : clearSelection()">
            Tout sélectionner (<span x-text="filtered.length"></span>)
        </label>
        <span x-show="selectedSalons.length > 0" style="color:var(--blue-light);">
            <span x-text="selectedSalons.length"></span> sélectionné<span x-show="selectedSalons.length > 1">s</span>
        </span>
    </div>

    {# ── Spinner ── #}
    <div x-show="loading" style="flex:1;display:flex;align-items:center;justify-content:center;">
        <div class="spinner"></div>
    </div>

    {# ── Grille de cartes ── #}
    <div class="cards-grid cards-grid--fill" x-show="!loading">
        <div x-show="filtered.length === 0" class="empty-state" style="grid-column:1/-1;">
            Aucun salon trouvé
        </div>
        <template x-for="salon in paginated" :key="salon.id">
            <div class="card" :class="['type-' + salon.Type, selectedSalons.includes(salon.id) ? 'card-selected' : '']"
                @click="selectMode && toggleSelectSalon(salon.id)">
                <div class="card-header">
                    <div style="display:flex;align-items:center;gap:8px;min-width:0;">
                        <input x-show="selectMode" type="checkbox"
                            :checked="selectedSalons.includes(salon.id)"
                            @click.stop
                            @change="toggleSelectSalon(salon.id)"
                            style="flex-shrink:0;cursor:pointer;">
                        <span class="card-name" x-text="salon.Nom || ''"></span>
                    </div>
                    <span class="card-type-badge" x-text="salon.Type || ''"></span>
                </div>
                <div class="card-meta" style="font-size:10px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    <span x-show="salon.room_id" x-text="salon.room_id"></span>
                    <span x-show="!salon.room_id" style="color:var(--red-light);">⚠ Pas de room_id</span>
                </div>

                {# Zone centrale flexible — absorbe l'espace variable pour que stats/bot/actions
                   soient toujours à la même position verticale dans toutes les vignettes #}
                <div class="card-middle">
                    <div class="card-desc" x-text="salon.Description || ''"></div>
                    <div class="card-unite-badges">
                        <template x-for="uid in getUniteIdsForSalon(salon.id)" :key="uid">
                            <span style="font-size:10px;background:rgba(45,108,223,.15);color:var(--blue-light);border-radius:4px;padding:1px 6px;"
                                x-text="unites.find(u => u.id === uid)?.Nom || '#' + uid"></span>
                        </template>
                    </div>
                </div>

                <div class="card-stats">
                    <div class="card-stat">
                        <span class="stat-value" x-text="getAgentCount(salon.id)"></span>
                        <span class="stat-label">Agents</span>
                    </div>
                    <div class="card-stat" x-show="!!salon.room_id">
                        <span class="stat-value" style="display:flex;align-items:center;gap:4px;">
                            <span :style="{ color: 'var(--blue-light)' }"
                                x-text="salon._memberCount !== undefined ? salon._memberCount : '—'"></span>
                            <span x-show="salon._inviteCount > 0"
                                style="font-size:9px;background:rgba(201,161,60,.2);color:var(--gold);border-radius:4px;padding:0 4px;font-weight:600;"
                                x-text="'+' + salon._inviteCount + 'inv'"></span>
                        </span>
                        <span class="stat-label">Tchap</span>
                    </div>
                </div>

                <div class="card-bot">
                    <template x-if="!!salon.room_id && salon._botPresent !== undefined">
                        <div>
                            <span :style="{ color: salon._botPresent ? '#6ec38a' : 'var(--red-light)', fontSize: '10px' }"
                                x-text="salon._botPresent ? '✓ Bot présent' : '✗ Bot absent'"></span>
                            <div x-show="salon._botUserId" style="font-size:9px;color:var(--text-muted);font-family:monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                x-text="salon._botUserId"></div>
                        </div>
                    </template>
                    <template x-if="!salon.room_id || salon._botPresent === undefined">
                        <span style="font-size:10px;color:var(--text-muted);">— non synchronisé</span>
                    </template>
                </div>

                <div class="card-actions" @click.stop>
                    <button class="btn-icon" @click="openModal('detail', salon)" title="Voir membres">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                    {% if permissions.canManage %}
                    <button class="btn-icon" x-show="!!salon.room_id" @click="openAddMembers(salon)"
                        title="Ajouter des membres" style="color:var(--green-light, #6ec38a);">
                        <i class="fa-solid fa-user-plus"></i>
                    </button>
                    <button class="btn-icon" x-show="!salon.room_id"
                        @click="createTchapRoom(salon)" title="Créer la room sur Tchap"
                        style="color:var(--gold);" :disabled="salon._loading">
                        <i class="fa-solid fa-plus" :class="{ 'fa-spin': salon._loading }"></i>
                    </button>
                    <button class="btn-icon" x-show="!!salon.room_id"
                        @click="fetchMembers(salon)" title="Rafraîchir les membres" style="color:var(--blue-light);"
                        :disabled="salon._loading">
                        <i class="fa-solid fa-rotate" :class="{ 'fa-spin': salon._loading }"></i>
                    </button>
                    <button class="btn-icon"
                        x-show="!!salon.room_id && salon._inviteCount > 0"
                        @click="reinviteSalon(salon)"
                        :disabled="salon._loading"
                        :title="'Renouveler ' + (salon._inviteCount ?? 0) + ' invitation(s) en attente'"
                        style="color:var(--gold);">
                        <i class="fa-solid fa-envelope-circle-check" style="font-size:12px;"></i>
                    </button>
                    <button class="btn-icon" @click="openModal('edit', salon)" title="Modifier">
                        <i class="fa-solid fa-pen"></i>
                    </button>
                    {% endif %}
                    {% if permissions.canAdmin %}
                    <button class="btn-icon" @click="startDeleteFlow(salon)" title="Supprimer" style="color:var(--red-light);">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                    {% endif %}
                </div>
            </div>
        </template>
    </div>

    {# ── Pagination ── toujours visible dès qu'il y a des salons #}
    <div class="pagination-bar" x-show="!loading && filtered.length > 0">
        <div class="pagination-size">
            Afficher
            <select x-model.number="perPage" @change="page = 1">
                <option value="12">12</option>
                <option value="24">24</option>
                <option value="48">48</option>
                <option value="96">96</option>
            </select>
            par page
        </div>
        <div class="pagination-info"
            x-text="filtered.length + ' salon' + (filtered.length > 1 ? 's' : '') + (totalPages > 1 ? ' — page ' + page + ' / ' + totalPages : '')"></div>
        <div class="pagination-controls" x-show="totalPages > 1">
            <button class="pagination-btn" :disabled="page === 1" @click="page--">&#8249;</button>
            <template x-for="p in visiblePages" :key="'p' + p">
                <span x-show="p === '...'" style="padding:0 4px;color:var(--text-muted);line-height:30px;">…</span>
                <button x-show="p !== '...'" class="pagination-btn" :class="{ active: p === page }"
                    @click="page = p" x-text="p"></button>
            </template>
            <button class="pagination-btn" :disabled="page === totalPages" @click="page++">&#8250;</button>
        </div>
    </div>

    {# ── Modal Créer / Modifier / Détail ── #}
    <div class="modal-overlay" x-show="modalOpen" x-cloak @click.self="closeModal()">
        <div class="modal">
            <div class="modal-header">
                <h3 x-text="modalMode === 'create' ? 'Créer un salon' : (modalMode === 'edit' ? 'Modifier un salon' : 'Détail salon')"></h3>
                <button class="btn-icon" @click="closeModal()"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <div x-show="modalError" class="alert-error" x-text="modalError"></div>

                <template x-if="modalMode === 'detail'">
                    <div class="detail-grid">
                        <div class="detail-row"><strong>Nom</strong><span x-text="form.Nom"></span></div>
                        <div class="detail-row"><strong>Type</strong><span x-text="form.Type"></span></div>
                        <div class="detail-row"><strong>Description</strong><span x-text="form.Description || '—'"></span></div>
                        <div class="detail-row"><strong>room_id</strong><span style="font-family:monospace;font-size:12px;" x-text="form.room_id || '—'"></span></div>
                        <div class="detail-row"><strong>Agents assignés</strong><span x-text="getAgentCount(form.id) + ' agent(s)'"></span></div>
                        <div class="detail-row">
                            <strong>Unités</strong>
                            <span x-text="getUniteIdsForSalon(form.id).map(uid => (unites.find(u => u.id === uid) || {}).Nom || ('#' + uid)).join(', ') || '—'"></span>
                        </div>
                    </div>
                </template>

                <template x-if="modalMode !== 'detail'">
                    <div class="form-grid">
                        <div class="form-group form-full">
                            <label>Nom *</label>
                            <input type="text" x-model="form.Nom" maxlength="200">
                        </div>
                        <div class="form-group">
                            <label>Type</label>
                            <select x-model="form.Type">
                                <option value="">— Sélectionner —</option>
                                <option value="operationnel">Opérationnel</option>
                                <option value="information">Information</option>
                                <option value="crise">Crise</option>
                                <option value="admin">Admin</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>room_id Matrix</label>
                            <input type="text" x-model="form.room_id" maxlength="200" placeholder="!roomid:serveur">
                        </div>
                        <div class="form-group form-full">
                            <label>Description</label>
                            <textarea x-model="form.Description" maxlength="500" rows="3"></textarea>
                        </div>
                        <div class="form-group form-full" x-show="unites.length > 0">
                            <label>
                                Unités associées
                                <span style="font-weight:400;color:var(--text-muted);margin-left:6px;" x-text="'(' + (form._uniteIds ? form._uniteIds.length : 0) + ' sélectionnée' + ((form._uniteIds && form._uniteIds.length > 1) ? 's' : '') + ')'"></span>
                            </label>
                            <input type="text" x-model="form._uniteSearch" placeholder="Filtrer les unités…"
                                style="width:100%;margin-bottom:6px;font-size:12px;padding:5px 8px;background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text-primary);">
                            <div class="multi-select" style="max-height:200px;overflow-y:auto;">
                                <template x-for="u in unites.filter(u => !form._uniteSearch || u.Nom.toLowerCase().includes(form._uniteSearch.toLowerCase()))" :key="u.id">
                                    <label class="multi-select-item">
                                        <input type="checkbox"
                                            :checked="form._uniteIds && form._uniteIds.includes(u.id)"
                                            @change="toggleUnite(u.id, $event.target.checked)">
                                        <span x-text="u.Nom"></span>
                                        <span x-show="u.code" style="margin-left:auto;font-size:10px;color:var(--text-muted);" x-text="u.code"></span>
                                    </label>
                                </template>
                                <div x-show="unites.filter(u => !form._uniteSearch || u.Nom.toLowerCase().includes(form._uniteSearch.toLowerCase())).length === 0"
                                    style="font-size:11px;color:var(--text-muted);padding:10px 8px;">
                                    Aucune unité correspondante
                                </div>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
            <div class="modal-footer" x-show="modalMode !== 'detail'">
                <button class="btn-ghost" @click="closeModal()">Annuler</button>
                <button class="btn-primary" :disabled="saving" @click="save()">
                    <i x-show="saving" class="fa-solid fa-spinner fa-spin"></i>
                    <span x-show="!saving" x-text="modalMode === 'create' ? 'Créer' : 'Enregistrer'"></span>
                </button>
            </div>
        </div>
    </div>

    {# ── Import CSV ── #}
    <div class="modal-overlay" x-show="importOpen" x-cloak @click.self="importOpen = false">
        <div class="modal">
            <div class="modal-header">
                <h3><i class="fa-solid fa-file-import"></i> Importer des salons (CSV)</h3>
                <button class="btn-icon" @click="importOpen = false"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <p style="font-size:12px;color:var(--text-secondary);margin-bottom:6px;">
                    Format : <code style="font-family:monospace;color:var(--gold);">Nom,Type,Description,room_id,Unites</code>
                </p>
                <p style="font-size:11px;color:var(--text-muted);margin-bottom:12px;">
                    La colonne <code style="font-family:monospace;">Unites</code> est optionnelle. Séparer les noms d'unités par <code style="font-family:monospace;">|</code> ou <code style="font-family:monospace;">;</code>. Les unités manquantes seront créées automatiquement.
                </p>
                <div class="form-group">
                    <label>Fichier CSV</label>
                    <input type="file" accept=".csv,text/csv" @change="loadCsv($event)" style="-webkit-appearance:auto;appearance:auto;color:var(--text-secondary);">
                </div>
                <div x-show="csvPreview.length > 0" style="margin-top:8px;">
                    <p style="font-size:13px;color:var(--text-secondary);" x-text="csvPreview.length + ' salon(s) à importer'"></p>
                </div>
                <div x-show="importError" class="alert-error" x-text="importError" style="margin-top:12px;"></div>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" @click="importOpen = false">Annuler</button>
                <button class="btn-primary" :disabled="csvPreview.length === 0 || importing" @click="importCsv()">
                    <i x-show="importing" class="fa-solid fa-spinner fa-spin"></i>
                    <span x-show="!importing">Importer</span>
                </button>
            </div>
        </div>
    </div>

    {# ── Modal Ajouter membres ── #}
    {# ── Modal Ajouter des membres ── #}
    <div class="modal-overlay" x-show="addMembersTarget" x-cloak @click.self="closeAddMembers()">
        <div class="modal" style="max-width:640px;width:95%;display:flex;flex-direction:column;max-height:85vh;">
            <div class="modal-header" style="flex-shrink:0;">
                <div>
                    <h3 style="margin:0;"><i class="fa-solid fa-user-plus" style="color:#6ec38a;margin-right:8px;"></i> Ajouter des membres</h3>
                    <div style="font-size:12px;color:var(--text-muted);margin-top:3px;">
                        Salon : <strong x-text="addMembersTarget ? addMembersTarget.Nom : ''"></strong>
                    </div>
                </div>
                <button class="btn-icon" @click="closeAddMembers()"><i class="fa-solid fa-xmark"></i></button>
            </div>

            {# ── Onglets ── #}
            <div style="display:flex;border-bottom:1px solid var(--border);background:var(--bg-elevated);flex-shrink:0;">
                <button class="import-tab-btn" :class="{ active: addMembersTab === 'personnel' }"
                    @click="addMembersTab = 'personnel'; addMembersResult = null; addMembersError = null;">
                    <i class="fa-solid fa-users" style="margin-right:5px;"></i> Personnel
                </button>
                <button class="import-tab-btn" :class="{ active: addMembersTab === 'csv' }"
                    @click="addMembersTab = 'csv'; addMembersResult = null; addMembersError = null;">
                    <i class="fa-solid fa-file-csv" style="margin-right:5px;"></i> Import CSV
                </button>
                <button class="import-tab-btn" :class="{ active: addMembersTab === 'manual' }"
                    @click="addMembersTab = 'manual'; addMembersResult = null; addMembersError = null;">
                    <i class="fa-solid fa-keyboard" style="margin-right:5px;"></i> Manuel
                </button>
            </div>

            <div class="modal-body" style="flex:1;overflow-y:auto;min-height:0;">

                {# ── Onglet Personnel ── #}
                <div x-show="addMembersTab === 'personnel'">
                    <div style="display:flex;gap:8px;margin-bottom:12px;align-items:center;">
                        <div style="position:relative;flex:1;">
                            <i class="fa-solid fa-magnifying-glass" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:12px;"></i>
                            <input type="text" x-model="addMembersSearch"
                                placeholder="Rechercher par nom, prénom, grade…"
                                style="padding-left:30px;width:100%;font-size:13px;">
                        </div>
                        <span style="font-size:12px;color:var(--text-muted);white-space:nowrap;"
                            x-text="addMembersSelected.length + ' sélectionné(s)'"></span>
                        <button class="btn-ghost" style="font-size:11px;padding:4px 10px;flex-shrink:0;"
                            x-show="addMembersSelected.length > 0"
                            @click="addMembersSelected = []">Tout désélectionner</button>
                    </div>

                    <div style="max-height:320px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--radius-sm);">
                        <template x-if="addMembersPersonnel.length === 0">
                            <div style="padding:20px;text-align:center;color:var(--text-muted);font-size:13px;">Aucun agent trouvé</div>
                        </template>
                        <template x-for="person in addMembersPersonnel" :key="person.id">
                            <div @click="!isAlreadyInRoom(person) && (person.user_id || person.Mail) ? toggleAddMembersPerson(person.id) : null"
                                :style="isAlreadyInRoom(person) || (!person.user_id && !person.Mail)
                                    ? 'opacity:.5;cursor:default;'
                                    : 'cursor:pointer;'"
                                :class="addMembersSelected.includes(person.id) ? 'bg-selected' : ''"
                                style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-bottom:1px solid var(--border);transition:background .1s;"
                                @mouseenter="if(!isAlreadyInRoom(person) && (person.user_id || person.Mail)) $el.style.background='var(--bg-hover)'"
                                @mouseleave="if(!addMembersSelected.includes(person.id)) $el.style.background=''">
                                {# Checkbox #}
                                <div style="flex-shrink:0;width:16px;height:16px;border-radius:3px;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;background:var(--bg-elevated);"
                                    :style="addMembersSelected.includes(person.id) ? 'background:var(--gold);border-color:var(--gold);' : ''">
                                    <i class="fa-solid fa-check" style="font-size:9px;color:#fff;"
                                        x-show="addMembersSelected.includes(person.id)"></i>
                                </div>
                                {# Avatar lettre #}
                                <div style="width:30px;height:30px;border-radius:50%;background:rgba(201,168,76,.2);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--gold);flex-shrink:0;"
                                    x-text="(person.Prenom||'?').charAt(0).toUpperCase()"></div>
                                {# Infos #}
                                <div style="flex:1;min-width:0;">
                                    <div style="font-size:13px;font-weight:600;" x-text="person.Prenom + ' ' + person.Nom"></div>
                                    <div style="font-size:11px;color:var(--text-muted);">
                                        <span x-show="person.Grade" x-text="person.Grade" style="margin-right:8px;"></span>
                                        {# Afficher user_id ou l'ID dérivé de l'email #}
                                        <span style="font-family:monospace;"
                                            :style="!person.user_id && person.Mail ? 'color:var(--gold);font-style:italic;' : ''"
                                            x-text="person.user_id || (person.Mail ? mailToTchapId(person.Mail) : '—')"></span>
                                    </div>
                                </div>
                                {# Badges état (join / invite / absent) #}
                                <div style="flex-shrink:0;display:flex;align-items:center;gap:6px;">
                                    <template x-if="getMemberStatus(person) === 'join'">
                                        <span style="font-size:10px;padding:2px 8px;border-radius:10px;background:rgba(110,195,138,.15);color:#6ec38a;border:1px solid rgba(110,195,138,.3);">
                                            présent
                                        </span>
                                    </template>
                                    <template x-if="getMemberStatus(person) === 'invite'">
                                        <span style="font-size:10px;padding:2px 8px;border-radius:10px;background:rgba(201,161,60,.15);color:var(--gold);border:1px solid rgba(201,161,60,.3);">
                                            invité
                                        </span>
                                    </template>
                                    <template x-if="getMemberStatus(person) === 'invite'">
                                        <button class="btn-icon" style="padding:2px 5px;color:var(--red-light);font-size:10px;"
                                            title="Expulser (retirer l'invitation)"
                                            @click.stop="kickMember(addMembersTarget, person.user_id)">
                                            <i class="fa-solid fa-user-xmark"></i>
                                        </button>
                                    </template>
                                    {# Badge autre administration #}
                                    <template x-if="getMemberStatus(person) === null && (person.user_id || person.Mail)">
                                        <span x-show="(person.user_id || mailToTchapId(person.Mail || '')).includes(':agent.') && !(person.user_id || mailToTchapId(person.Mail || '')).includes(':agent.interieur.')"
                                            style="font-size:10px;padding:2px 6px;border-radius:10px;background:rgba(45,108,223,.1);color:var(--blue-light);border:1px solid rgba(45,108,223,.2);">
                                            autre admin
                                        </span>
                                    </template>
                                    <span x-show="!person.user_id && !person.Mail && getMemberStatus(person) === null"
                                        style="font-size:10px;padding:2px 8px;border-radius:10px;background:rgba(192,57,43,.1);color:var(--red-light);border:1px solid rgba(192,57,43,.2);">
                                        pas de compte Tchap
                                    </span>
                                </div>
                            </div>
                        </template>
                    </div>
                </div>

                {# ── Onglet Import CSV ── #}
                <div x-show="addMembersTab === 'csv'">
                    <div style="margin-bottom:12px;font-size:12px;color:var(--text-secondary);line-height:1.6;">
                        Importez un fichier <strong>.csv</strong> contenant des adresses email ou des identifiants Matrix
                        (<code style="font-size:11px;">@prenom.nom:serveur</code>). Les emails sont automatiquement associés au personnel.
                    </div>

                    <label style="display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;padding:20px;border:2px dashed var(--border);border-radius:var(--radius-sm);cursor:pointer;background:var(--bg-elevated);margin-bottom:12px;"
                        @dragover.prevent="$el.style.borderColor='var(--gold)'"
                        @dragleave="$el.style.borderColor=''"
                        @drop.prevent="$el.style.borderColor=''; parseCsvForMembers({ target: { files: $event.dataTransfer.files } })">
                        <i class="fa-solid fa-file-arrow-up" style="font-size:24px;color:var(--text-muted);"></i>
                        <span style="font-size:13px;color:var(--text-secondary);">Glisser-déposer ou <strong style="color:var(--gold);">cliquer pour choisir</strong></span>
                        <span style="font-size:11px;color:var(--text-muted);">.csv — colonnes séparées par virgule ou point-virgule</span>
                        <input type="file" accept=".csv,text/csv" style="display:none;" @change="parseCsvForMembers($event)">
                    </label>

                    <div x-show="addMembersCsvError" class="alert-error" x-text="addMembersCsvError" style="margin-bottom:10px;"></div>

                    <template x-if="addMembersCsvRows.length > 0">
                        <div>
                            <div style="font-size:12px;font-weight:700;color:var(--text-primary);margin-bottom:8px;">
                                Aperçu —
                                <span style="color:#6ec38a;" x-text="addMembersCsvRows.filter(r=>r.matched).length + ' trouvé(s)'"></span>
                                <span x-show="addMembersCsvRows.filter(r=>!r.matched).length > 0"
                                    style="color:var(--red-light);margin-left:8px;"
                                    x-text="addMembersCsvRows.filter(r=>!r.matched).length + ' non trouvé(s)'"></span>
                            </div>
                            <div style="max-height:200px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--radius-sm);">
                                <template x-for="(row, i) in addMembersCsvRows" :key="i">
                                    <div style="display:flex;align-items:center;gap:10px;padding:6px 12px;border-bottom:1px solid var(--border);font-size:12px;">
                                        <i :class="row.matched ? 'fa-solid fa-circle-check' : 'fa-solid fa-circle-xmark'"
                                            :style="row.matched ? 'color:#6ec38a' : 'color:var(--red-light)'"></i>
                                        <div style="flex:1;min-width:0;">
                                            <div x-text="row.name" style="font-weight:600;"></div>
                                            <div x-show="row.email && row.userId" style="color:var(--text-muted);font-family:monospace;font-size:11px;" x-text="row.userId"></div>
                                            <div x-show="!row.matched" style="color:var(--red-light);font-size:11px;">Introuvable dans le personnel</div>
                                        </div>
                                        <div x-show="isAlreadyInRoom({ user_id: row.userId })"
                                            style="font-size:10px;padding:2px 7px;border-radius:10px;background:rgba(110,195,138,.15);color:#6ec38a;border:1px solid rgba(110,195,138,.3);">
                                            déjà présent
                                        </div>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </template>
                </div>

                {# ── Onglet Manuel ── #}
                <div x-show="addMembersTab === 'manual'">
                    <div class="form-group">
                        <label>Adresses email ou identifiants Matrix <small style="color:var(--text-muted);">(un par ligne)</small></label>
                        <textarea x-model="addMembersInput" rows="8"
                            placeholder="prenom.nom@gendarmerie.interieur.gouv.fr&#10;prenom.nom@diplomatie.gouv.fr&#10;@prenom.nom-domaine.gouv.fr:agent.ministere.tchap.gouv.fr"
                            style="font-family:monospace;font-size:12px;"></textarea>
                        <small style="color:var(--text-muted);display:block;margin-top:4px;">
                            Les emails sont convertis automatiquement vers le bon homeserver Tchap selon l'administration.
                        </small>
                    </div>
                </div>

                {# ── Messages retour ── #}
                <div x-show="addMembersError" class="alert-error" x-text="addMembersError" style="margin-top:10px;white-space:pre-wrap;"></div>
                <div x-show="addMembersResult && !addMembersError"
                    style="margin-top:10px;padding:8px 12px;background:rgba(110,195,138,.08);border:1px solid rgba(110,195,138,.3);border-radius:var(--radius-sm);font-size:13px;color:#6ec38a;"
                    x-text="addMembersResult"></div>
            </div>

            <div class="modal-footer" style="flex-shrink:0;">
                <button class="btn-ghost" @click="closeAddMembers()">Fermer</button>
                <button class="btn-primary" :disabled="saving
                    || (addMembersTab === 'personnel' && addMembersSelected.length === 0)
                    || (addMembersTab === 'manual'    && !addMembersInput.trim())
                    || (addMembersTab === 'csv'       && addMembersCsvRows.filter(r=>r.matched).length === 0)"
                    @click="addMembers()" style="min-width:120px;">
                    <i x-show="saving" class="fa-solid fa-spinner fa-spin"></i>
                    <span x-show="!saving">
                        <i class="fa-solid fa-paper-plane"></i>
                        <span x-show="addMembersTab === 'personnel'" x-text="'Inviter (' + addMembersSelected.length + ')'"></span>
                        <span x-show="addMembersTab === 'csv'"       x-text="'Inviter (' + addMembersCsvRows.filter(r=>r.matched).length + ')'"></span>
                        <span x-show="addMembersTab === 'manual'">Inviter</span>
                    </span>
                </button>
            </div>
        </div>
    </div>

    {# ── Modal Suppression multi-étapes ── #}
    <div class="modal-overlay" x-show="deleteStep > 0" x-cloak>
        <div class="modal modal-sm">

            {# Étape 1 : confirmation initiale #}
            <template x-if="deleteStep === 1">
                <div>
                    <div class="modal-header">
                        <h3><i class="fa-solid fa-triangle-exclamation" style="color:var(--red-light);"></i> Supprimer le salon</h3>
                    </div>
                    <div class="modal-body">
                        <p>Supprimer le salon <strong x-text="deleteTarget ? deleteTarget.Nom : (deleteBulkIds.length + ' salons')"></strong> ?</p>
                        <p x-show="deleteTarget && deleteTarget.room_id" style="margin-top:10px;font-size:12px;color:var(--text-secondary);">
                            <i class="fa-solid fa-circle-info"></i>
                            Tous les membres seront d'abord expulsés du salon Tchap, puis vous pourrez choisir si le bot doit aussi quitter le salon.
                        </p>
                        <p x-show="deleteTarget && !deleteTarget.room_id" style="margin-top:10px;font-size:12px;color:var(--text-muted);">
                            Ce salon n'a pas de room_id — aucune action Tchap ne sera effectuée.
                        </p>
                        <p x-show="deleteBulkIds.length > 0" style="margin-top:10px;font-size:12px;color:var(--text-secondary);">
                            <i class="fa-solid fa-circle-info"></i>
                            Pour chaque salon ayant un room_id, tous les membres seront expulsés et le bot quittera le salon.
                        </p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn-ghost" @click="cancelDelete()">Annuler</button>
                        <button class="btn-danger" :disabled="saving" @click="runKickUsers()">
                            <i x-show="saving" class="fa-solid fa-spinner fa-spin"></i>
                            <span x-show="!saving">Continuer</span>
                        </button>
                    </div>
                </div>
            </template>

            {# Étape 2 : expulsion en cours / résultat #}
            <template x-if="deleteStep === 2">
                <div>
                    <div class="modal-header">
                        <h3><i class="fa-solid fa-spinner fa-spin" style="color:var(--blue-light);"></i> Expulsion des membres…</h3>
                    </div>
                    <div class="modal-body">
                        <p style="font-size:13px;color:var(--text-secondary);">Expulsion des membres Tchap en cours, veuillez patienter…</p>
                    </div>
                    <div class="modal-footer"></div>
                </div>
            </template>

            {# Étape 3 : confirmation suppression du bot #}
            <template x-if="deleteStep === 3">
                <div>
                    <div class="modal-header">
                        <h3><i class="fa-solid fa-robot" style="color:var(--gold);"></i> Suppression du bot</h3>
                    </div>
                    <div class="modal-body">
                        <p x-show="deleteKickResult !== null" style="margin-bottom:10px;font-size:12px;color:#6ec38a;">
                            <i class="fa-solid fa-check"></i>
                            <span x-text="deleteKickResult"></span>
                        </p>
                        <p>Voulez-vous également faire quitter le <strong>bot</strong> du salon Tchap ?</p>
                        <p style="font-size:11px;color:var(--text-muted);margin-top:6px;">
                            Si vous gardez le bot, il restera membre du salon Tchap même après la suppression dans cette application.
                        </p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn-ghost" :disabled="saving" @click="skipBotLeave()">Non, garder le bot</button>
                        <button class="btn-danger" :disabled="saving" @click="runBotLeave()">
                            <i x-show="saving" class="fa-solid fa-spinner fa-spin"></i>
                            <span x-show="!saving">Oui, expulser le bot</span>
                        </button>
                    </div>
                </div>
            </template>

            {# Étape 4 : suppression définitive dans l'app #}
            <template x-if="deleteStep === 4">
                <div>
                    <div class="modal-header">
                        <h3><i class="fa-solid fa-trash" style="color:var(--red-light);"></i> Suppression définitive</h3>
                    </div>
                    <div class="modal-body">
                        <p>Supprimer définitivement le salon <strong x-text="deleteTarget ? deleteTarget.Nom : (deleteBulkIds.length + ' salons')"></strong> de l'application de gestion ?</p>
                        <p style="font-size:11px;color:var(--text-muted);margin-top:6px;">Cette action est irréversible.</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn-ghost" @click="cancelDelete()">Annuler</button>
                        <button class="btn-danger" :disabled="saving" @click="finishDelete()">
                            <i x-show="saving" class="fa-solid fa-spinner fa-spin"></i>
                            <span x-show="!saving">Supprimer de l'application</span>
                        </button>
                    </div>
                </div>
            </template>

        </div>
    </div>

</div>
{% endblock %}

{% block head_extra %}
<style>
/*
 * Grille fixe 6 colonnes × 2 lignes — remplit l'espace entre toolbar et pagination.
 * La pagination est réglée sur 12 éléments (6×2) pour correspondre exactement.
 */
.cards-grid--fill {
    overflow: hidden;
    padding: 10px 16px;
    gap: 10px;
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(2, 1fr);
    grid-auto-rows: 0;        /* lignes implicites (items > 12) écrasées à 0 */
    align-content: stretch;
}

/* Carte : remplit sa cellule, layout colonne strict */
.cards-grid--fill .card {
    min-height: 0;
    height: 100%;
    overflow: hidden;
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 0;
}

/* Nom : tronqué sur une ligne, taille fluide */
.cards-grid--fill .card-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: clamp(10px, 1vw, 14px);
}

/* Type badge : compact */
.cards-grid--fill .card-type-badge {
    font-size: 9px;
    padding: 1px 5px;
}

/* room_id : une ligne tronquée */
.cards-grid--fill .card-meta {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 9px;
    margin-bottom: 4px;
    flex-shrink: 0;
}

/* ── Zone centrale flexible ──────────────────────────────────────────────────
   Absorbe tout l'espace disponible entre card-meta et card-stats.
   Description et badges y vivent toujours, juste vides si rien à afficher.
   Garantit que stats/bot/actions sont au même endroit dans toutes les cartes. */
.cards-grid--fill .card-middle {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 3px;
}

/* Description : 2 lignes max, toujours présente (vide si pas de description) */
.cards-grid--fill .card-desc {
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    font-size: 11px;
    color: var(--text-secondary);
    flex-shrink: 0;
    line-height: 1.4;
}

/* Badges unités : 1 rangée max, toujours présents */
.cards-grid--fill .card-unite-badges {
    display: flex;
    flex-wrap: nowrap;
    gap: 3px;
    overflow: hidden;
    flex-shrink: 0;
}

/* Stats : fixes en bas de la zone centrale */
.cards-grid--fill .card-stats {
    flex-shrink: 0;
    padding-top: 4px;
    margin-top: 4px;
    gap: 10px;
}
.cards-grid--fill .stat-value { font-size: clamp(12px, 1.2vw, 18px); }
.cards-grid--fill .stat-label { font-size: 9px; }

/* Bot status : hauteur fixe, toujours présent */
.cards-grid--fill .card-bot {
    flex-shrink: 0;
    height: 26px;
    overflow: hidden;
    margin-top: 3px;
    font-size: 10px;
}

/* Boutons d'action : compacts */
.cards-grid--fill .card-actions {
    flex-shrink: 0;
    padding-top: 5px;
    gap: 3px;
}
.cards-grid--fill .btn-icon {
    width: 24px;
    height: 24px;
    font-size: 11px;
}
</style>
{% endblock %}
