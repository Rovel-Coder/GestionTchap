{% extends 'base.html.twig' %}

{% block title %}Espaces — Gestion Tchap{% endblock %}

{% block content %}
<div class="view" x-data="espaceView()" x-init="load()">

    {# ── Toolbar ── #}
    <div class="view-toolbar">
        <div class="toolbar-left">
            <span class="view-title">ESPACES TCHAP</span>
            <span class="badge" x-text="espaces.length + ' espace' + (espaces.length > 1 ? 's' : '')"></span>
        </div>
        <div class="toolbar-right">
            {% if permissions.canManage %}
            <button class="btn-primary" @click="openModal('create')">
                <i class="fa-solid fa-plus"></i> Créer un espace
            </button>
            {% endif %}
        </div>
    </div>

    {# ── Spinner ── #}
    <div x-show="loading" style="flex:1;display:flex;align-items:center;justify-content:center;">
        <div class="spinner"></div>
    </div>

    {# ── Grille de cartes ── #}
    <div class="cards-grid" x-show="!loading">
        <div x-show="espaces.length === 0" class="empty-state" style="grid-column:1/-1;">
            Aucun espace — créez-en un pour regrouper vos salons Tchap.
        </div>

        <template x-for="espace in espaces" :key="espace.id">
            <div class="card espace-card">

                {# En-tête #}
                <div class="card-header">
                    <div style="display:flex;align-items:center;gap:8px;min-width:0;">
                        <i class="fa-solid fa-layer-group" style="color:var(--gold);flex-shrink:0;font-size:13px;"></i>
                        <span class="card-name" x-text="espace.Nom"></span>
                    </div>
                    <span class="card-type-badge" x-show="espace.space_id"
                        style="background:rgba(110,195,138,.15);color:#6ec38a;">Tchap ✓</span>
                    <span class="card-type-badge" x-show="!espace.space_id"
                        style="background:rgba(192,57,43,.08);color:var(--red-light);">Non créé</span>
                </div>

                {# space_id ou warning — toujours sur 1 ligne #}
                <div class="card-meta ec-meta">
                    <span x-show="espace.space_id" style="font-family:monospace;" x-text="espace.space_id"></span>
                    <span x-show="!espace.space_id" style="color:var(--red-light);">⚠ Pas de space_id</span>
                </div>

                {# Zone centrale flexible — description + salons liés #}
                <div class="card-middle">

                    {# Description : toujours présente, vide si aucune #}
                    <div class="card-desc ec-desc" x-text="espace.Description || ''"></div>

                    {# Salons liés #}
                    <div class="ec-salons">
                        <div class="ec-salons-header">
                            <i class="fa-solid fa-comments"></i>
                            <span x-text="(espace._salons?.length ?? 0) + ' salon' + ((espace._salons?.length ?? 0) > 1 ? 's' : '')"></span>
                        </div>
                        <div class="ec-salons-pills">
                            <template x-if="espace._salons?.length === 0">
                                <span class="ec-empty">Aucun salon associé</span>
                            </template>
                            <template x-for="salon in espace._salons" :key="salon.id">
                                <span class="ec-pill">
                                    <span x-text="salon.Nom"></span>
                                    {% if permissions.canManage %}
                                    <button @click.stop="removeSalon(espace, salon)"
                                        :disabled="espace._loading" title="Retirer ce salon"
                                        style="background:none;border:none;cursor:pointer;color:var(--text-muted);padding:0;line-height:1;font-size:9px;">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                    {% endif %}
                                </span>
                            </template>
                        </div>
                    </div>

                </div>

                {# Membres Tchap + erreur — hauteur fixe #}
                <div class="ec-status">
                    <template x-if="espace._memberCount !== null">
                        <span>
                            <span style="color:#6ec38a;" x-text="'✓ ' + (espace._memberCount?.joined ?? 0) + ' membre(s)'"></span>
                            <span x-show="espace._memberCount?.invited > 0" style="color:var(--gold);margin-left:6px;"
                                x-text="'+ ' + espace._memberCount.invited + ' en attente'"></span>
                        </span>
                    </template>
                    <template x-if="espace._error">
                        <span style="color:var(--red-light);" x-text="espace._error"></span>
                    </template>
                </div>

                {# Actions — toujours en bas #}
                <div class="card-actions">
                    {% if permissions.canManage %}
                    <button class="btn-icon" x-show="!espace.space_id"
                        @click="createTchapSpace(espace)" :disabled="espace._loading"
                        title="Créer l'espace sur Tchap" style="color:var(--gold);">
                        <i class="fa-solid fa-plus" :class="{ 'fa-spin': espace._loading }"></i>
                    </button>
                    <button class="btn-icon" x-show="espace.space_id"
                        @click="openMembersModal(espace)" :disabled="espace._loading"
                        title="Voir les membres de l'espace" style="color:#6ec38a;">
                        <i class="fa-solid fa-users"></i>
                    </button>
                    <button class="btn-icon" x-show="espace.space_id && espace._salons?.length > 0"
                        @click="syncMembers(espace)" :disabled="espace._loading"
                        title="Inviter dans l'espace les membres de tous les salons liés"
                        style="color:var(--blue-light);">
                        <i class="fa-solid fa-rotate" :class="{ 'fa-spin': espace._loading }"></i>
                    </button>
                    <button class="btn-icon" x-show="espace.space_id"
                        @click="openInviteModal(espace)" title="Inviter dans l'espace"
                        style="color:var(--blue-light);">
                        <i class="fa-solid fa-user-plus"></i>
                    </button>
                    <button class="btn-icon" @click="openAddSalonModal(espace)"
                        :disabled="espace._loading" title="Gérer les salons">
                        <i class="fa-solid fa-sliders"></i>
                    </button>
                    <button class="btn-icon" @click="openModal('edit', espace)" title="Modifier">
                        <i class="fa-solid fa-pen"></i>
                    </button>
                    {% endif %}
                    {% if permissions.canAdmin %}
                    <button class="btn-icon" @click="startDelete(espace)"
                        title="Supprimer" style="color:var(--red-light);">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                    {% endif %}
                </div>

            </div>
        </template>
    </div>

    {# ── Modal Créer / Modifier ── #}
    <div class="modal-overlay" x-show="modalOpen" x-cloak @click.self="closeModal()">
        <div class="modal">
            <div class="modal-header">
                <h3 x-text="modalMode === 'create' ? 'Créer un espace' : 'Modifier l\'espace'"></h3>
                <button class="btn-icon" @click="closeModal()"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <div x-show="modalError" class="alert-error" x-text="modalError"></div>
                <div class="form-grid">
                    <div class="form-group form-full">
                        <label>Nom *</label>
                        <input type="text" x-model="form.Nom" maxlength="200" placeholder="Nom de l'espace">
                    </div>
                    <div class="form-group form-full">
                        <label>Description</label>
                        <textarea x-model="form.Description" maxlength="500" rows="3"
                            placeholder="Description visible dans Tchap"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" @click="closeModal()">Annuler</button>
                <button class="btn-primary" :disabled="saving" @click="save()">
                    <i x-show="saving" class="fa-solid fa-spinner fa-spin"></i>
                    <span x-show="!saving" x-text="modalMode === 'create' ? 'Créer' : 'Enregistrer'"></span>
                </button>
            </div>
        </div>
    </div>

    {# ── Modal Gérer les salons ── #}
    <div class="modal-overlay" x-show="addSalonTarget !== null" x-cloak @click.self="closeAddSalonModal()">
        <div class="modal" style="max-width:560px;">
            <div class="modal-header">
                <div>
                    <h3 style="margin:0;"><i class="fa-solid fa-sliders" style="color:var(--gold);margin-right:8px;"></i> Gérer les salons</h3>
                    <div style="font-size:12px;color:var(--text-muted);margin-top:3px;" x-text="addSalonTarget ? addSalonTarget.Nom : ''"></div>
                </div>
                <button class="btn-icon" @click="closeAddSalonModal()"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <div x-show="addSalonError" class="alert-error" x-text="addSalonError" style="margin-bottom:10px;"></div>

                <p style="font-size:12px;color:var(--text-secondary);margin-bottom:10px;">
                    Sélectionnez les salons à ajouter. Seuls les salons ayant un <code style="font-family:monospace;">room_id</code> peuvent être liés sur Tchap.
                </p>

                <input type="text" x-model="addSalonSearch" placeholder="Filtrer les salons…"
                    style="width:100%;margin-bottom:10px;font-size:12px;padding:6px 10px;background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text-primary);">

                <div style="max-height:300px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--radius-sm);">
                    <template x-if="availableSalons().length === 0">
                        <div style="padding:20px;text-align:center;color:var(--text-muted);font-size:13px;">
                            Tous les salons sont déjà dans cet espace, ou aucun salon n'existe.
                        </div>
                    </template>
                    <template x-for="salon in availableSalons()" :key="salon.id">
                        <div style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-bottom:1px solid var(--border);">
                            <i class="fa-solid fa-comments" style="color:var(--text-muted);font-size:12px;flex-shrink:0;"></i>
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:13px;font-weight:600;" x-text="salon.Nom"></div>
                                <div style="font-size:10px;color:var(--text-muted);font-family:monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                    x-text="salon.room_id || '— pas de room_id'"></div>
                            </div>
                            <span x-show="!salon.room_id && addSalonTarget && addSalonTarget.space_id"
                                style="font-size:10px;color:var(--text-muted);">lien Tchap impossible</span>
                            <button class="btn-ghost" style="font-size:11px;padding:4px 10px;flex-shrink:0;"
                                :disabled="addSalonTarget && addSalonTarget._loading"
                                @click="doAddSalon(salon)">
                                <i class="fa-solid fa-plus"></i> Ajouter
                            </button>
                        </div>
                    </template>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" @click="closeAddSalonModal()">Fermer</button>
            </div>
        </div>
    </div>

    {# ── Modal Inviter un membre ── #}
    <div class="modal-overlay" x-show="inviteTarget !== null" x-cloak @click.self="closeInviteModal()">
        <div class="modal" style="max-width:520px;width:95vw;">
            <div class="modal-header">
                <div>
                    <h3 style="margin:0;"><i class="fa-solid fa-user-plus" style="color:var(--blue-light);margin-right:8px;"></i> Inviter dans l'espace</h3>
                    <div style="font-size:12px;color:var(--text-muted);margin-top:3px;" x-text="inviteTarget ? inviteTarget.Nom : ''"></div>
                </div>
                <button class="btn-icon" @click="closeInviteModal()"><i class="fa-solid fa-xmark"></i></button>
            </div>

            {# Onglets #}
            <div style="display:flex;border-bottom:1px solid var(--border);background:var(--bg-elevated);">
                <button class="import-tab-btn" :class="{ active: inviteTab === 'personnel' }"
                    @click="inviteTab = 'personnel'; inviteError = null; inviteSuccess = null">
                    <i class="fa-solid fa-users" style="margin-right:5px;font-size:11px;"></i>Personnel
                    <span x-show="inviteSelected.length > 0"
                        style="margin-left:5px;background:var(--blue);border-radius:10px;padding:1px 6px;font-size:10px;"
                        x-text="inviteSelected.length"></span>
                </button>
                <button class="import-tab-btn" :class="{ active: inviteTab === 'manual' }"
                    @click="inviteTab = 'manual'; inviteError = null; inviteSuccess = null">
                    <i class="fa-solid fa-keyboard" style="margin-right:5px;font-size:11px;"></i>Manuel
                </button>
            </div>

            <div class="modal-body" style="padding:0;">

                {# ── Onglet Personnel ── #}
                <div x-show="inviteTab === 'personnel'" style="padding:14px 16px;">
                    <div x-show="inviteSuccess"
                        style="margin-bottom:10px;padding:7px 12px;background:rgba(110,195,138,.08);border:1px solid rgba(110,195,138,.3);border-radius:var(--radius-sm);font-size:13px;color:#6ec38a;"
                        x-text="inviteSuccess"></div>
                    <div x-show="inviteError" class="alert-error" x-text="inviteError" style="margin-bottom:10px;white-space:pre-wrap;"></div>

                    <input type="text" x-model="inviteSearch" placeholder="Filtrer par nom, prénom, email…"
                        style="width:100%;margin-bottom:8px;font-size:12px;padding:6px 10px;background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text-primary);">

                    <div style="border:1px solid var(--border);border-radius:var(--radius-sm);max-height:280px;overflow-y:auto;">
                        <template x-for="person in invitePersonnelFiltered.slice(0, 50)" :key="person.id">
                            <label style="display:flex;align-items:center;gap:10px;padding:7px 12px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .1s;"
                                @mouseenter="$el.style.background='var(--bg-hover)'"
                                @mouseleave="$el.style.background=''">
                                <input type="checkbox"
                                    :checked="inviteSelected.includes(person.id)"
                                    @change="toggleInvitePerson(person.id)"
                                    style="flex-shrink:0;accent-color:var(--blue-light);">
                                <div style="width:28px;height:28px;border-radius:50%;background:rgba(45,108,223,.15);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--blue-light);flex-shrink:0;"
                                    x-text="(person.Prenom||'?').charAt(0).toUpperCase()"></div>
                                <div style="flex:1;min-width:0;">
                                    <div style="font-size:13px;font-weight:600;" x-text="person.Prenom + ' ' + person.Nom"></div>
                                    <div style="font-size:11px;color:var(--text-muted);font-family:monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                        x-text="person.user_id || person.Mail || '—'"></div>
                                </div>
                                <span x-show="person.Grade" style="font-size:10px;color:var(--text-muted);flex-shrink:0;" x-text="person.Grade"></span>
                            </label>
                        </template>
                        <div x-show="invitePersonnelFiltered.length === 0"
                            style="padding:20px;text-align:center;color:var(--text-muted);font-size:12px;">
                            Aucun agent avec un compte Tchap trouvé
                        </div>
                    </div>

                    <div x-show="invitePersonnelFiltered.length > 50"
                        style="font-size:11px;color:var(--text-muted);margin-top:5px;text-align:center;">
                        Affichage des 50 premiers résultats — affinez la recherche
                    </div>
                </div>

                {# ── Onglet Manuel ── #}
                <div x-show="inviteTab === 'manual'" style="padding:14px 16px;">
                    <div x-show="inviteSuccess"
                        style="margin-bottom:10px;padding:7px 12px;background:rgba(110,195,138,.08);border:1px solid rgba(110,195,138,.3);border-radius:var(--radius-sm);font-size:13px;color:#6ec38a;"
                        x-text="inviteSuccess"></div>
                    <div x-show="inviteError" class="alert-error" x-text="inviteError" style="margin-bottom:10px;white-space:pre-wrap;"></div>
                    <div class="form-group">
                        <label>Adresses email ou identifiants Matrix <small style="color:var(--text-muted);">(un par ligne)</small></label>
                        <textarea x-model="inviteManual" rows="5"
                            placeholder="prenom.nom@diplomatie.gouv.fr&#10;@prenom.nom-domaine.gouv.fr:agent.ministere.tchap.gouv.fr"
                            style="font-family:monospace;font-size:12px;"></textarea>
                        <small style="color:var(--text-muted);">Les emails sont convertis automatiquement vers le bon homeserver Tchap.</small>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-ghost" @click="closeInviteModal()">Fermer</button>
                <button class="btn-primary"
                    :disabled="saving || (inviteTab === 'personnel' && inviteSelected.length === 0) || (inviteTab === 'manual' && !inviteManual.trim())"
                    @click="doInvite()">
                    <i x-show="saving" class="fa-solid fa-spinner fa-spin"></i>
                    <span x-show="!saving">
                        <i class="fa-solid fa-paper-plane"></i>
                        <span x-show="inviteTab === 'personnel' && inviteSelected.length > 0"
                            x-text="'Inviter (' + inviteSelected.length + ')'"></span>
                        <span x-show="inviteTab !== 'personnel' || inviteSelected.length === 0">Inviter</span>
                    </span>
                </button>
            </div>
        </div>
    </div>

    {# ── Modal Membres de l'espace ── #}
    <div class="modal-overlay" x-show="membersTarget !== null" x-cloak @click.self="closeMembersModal()">
        <div class="modal" style="max-width:520px;width:95vw;display:flex;flex-direction:column;max-height:80vh;">
            <div class="modal-header" style="flex-shrink:0;">
                <div>
                    <h3 style="margin:0;"><i class="fa-solid fa-users" style="color:#6ec38a;margin-right:8px;"></i>Membres de l'espace</h3>
                    <div style="font-size:12px;color:var(--text-muted);margin-top:3px;" x-text="membersTarget?.Nom ?? ''"></div>
                </div>
                <button class="btn-icon" @click="closeMembersModal()"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div class="modal-body" style="flex:1;overflow-y:auto;min-height:0;">
                <div x-show="membersLoading" style="display:flex;justify-content:center;padding:20px;">
                    <div class="spinner"></div>
                </div>
                <div x-show="membersError" class="alert-error" x-text="membersError"></div>

                <template x-if="!membersLoading && !membersError">
                    <div>
                        {# Résumé #}
                        <div style="display:flex;gap:12px;margin-bottom:12px;font-size:12px;">
                            <span style="color:#6ec38a;">
                                <i class="fa-solid fa-circle-check" style="margin-right:4px;font-size:10px;"></i>
                                <span x-text="membersList.filter(m=>m.membership==='join').length"></span> présents
                            </span>
                            <span x-show="membersList.filter(m=>m.membership==='invite').length > 0" style="color:var(--gold);">
                                <i class="fa-solid fa-envelope" style="margin-right:4px;font-size:10px;"></i>
                                <span x-text="membersList.filter(m=>m.membership==='invite').length"></span> invités
                            </span>
                            <span x-show="membersList.length === 0" style="color:var(--text-muted);">Aucun membre</span>
                        </div>

                        {# Liste #}
                        <div style="border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;">
                            <template x-for="m in membersList" :key="m.userId">
                                <div style="display:flex;align-items:center;gap:10px;padding:7px 12px;border-bottom:1px solid var(--border);font-size:12px;">
                                    <div style="width:28px;height:28px;border-radius:50%;background:var(--bg-elevated);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:11px;color:var(--text-muted);">
                                        <i class="fa-solid fa-user"></i>
                                    </div>
                                    <span style="flex:1;font-family:monospace;font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--text-secondary);"
                                        x-text="m.userId"></span>
                                    <span class="ec-member-badge" :class="m.membership"
                                        x-text="{ join:'Présent', invite:'Invité', leave:'Parti', ban:'Banni' }[m.membership] ?? m.membership">
                                    </span>
                                </div>
                            </template>
                            <div x-show="membersList.length === 0" style="padding:20px;text-align:center;color:var(--text-muted);font-size:12px;">
                                Aucun membre dans cet espace
                            </div>
                        </div>
                    </div>
                </template>
            </div>

            <div class="modal-footer" style="flex-shrink:0;">
                <button class="btn-ghost" @click="closeMembersModal()">Fermer</button>
                <button class="btn-ghost" @click="openInviteModal(membersTarget); closeMembersModal()"
                    x-show="membersTarget?.space_id" style="color:var(--blue-light);">
                    <i class="fa-solid fa-user-plus"></i> Inviter
                </button>
            </div>
        </div>
    </div>

    {# ── Modal Suppression ── #}
    <div class="modal-overlay" x-show="deleteTarget !== null" x-cloak>
        <div class="modal modal-sm">
            <div class="modal-header">
                <h3><i class="fa-solid fa-triangle-exclamation" style="color:var(--red-light);"></i> Supprimer l'espace</h3>
            </div>
            <div class="modal-body">
                <p>Supprimer l'espace <strong x-text="deleteTarget ? deleteTarget.Nom : ''"></strong> de l'application ?</p>
                <p style="margin-top:8px;font-size:12px;color:var(--text-secondary);">
                    <i class="fa-solid fa-circle-info"></i>
                    L'espace Tchap ne sera <strong>pas supprimé</strong> sur le serveur — le bot le quittera simplement.
                    Les salons liés restent intacts.
                </p>
                <div x-show="deleteError" class="alert-error" style="margin-top:10px;" x-text="deleteError"></div>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" @click="cancelDelete()">Annuler</button>
                <button class="btn-danger" :disabled="saving" @click="doDelete()">
                    <i x-show="saving" class="fa-solid fa-spinner fa-spin"></i>
                    <span x-show="!saving">Supprimer</span>
                </button>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block head_extra %}
<style>
/* ── Vignettes espaces — structure uniforme ────────────────────────────── */
.espace-card {
    display: flex;
    flex-direction: column;
    height: 270px;      /* hauteur fixe : toutes les cartes identiques */
    min-height: 0;
    overflow: hidden;
}

/* Nom : une seule ligne, tronquée */
.espace-card .card-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* space_id monospace tronqué */
.espace-card .ec-meta {
    font-size: 9px;
    font-family: monospace;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-bottom: 4px;
    flex-shrink: 0;
    color: var(--text-muted);
    height: 13px;
}

/* Zone centrale flexible */
.espace-card .card-middle {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 5px;
}

/* Description : 1 ligne max */
.espace-card .ec-desc {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 11px;
    color: var(--text-secondary);
    flex-shrink: 0;
    height: 16px;
}

/* Compteur salons */
.ec-salons-header {
    font-size: 10px;
    font-weight: 600;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 5px;
    flex-shrink: 0;
}

/* Pills : 2 rangées max, overflow hidden — pas de scrollbar */
.ec-salons-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 3px;
    overflow: hidden;
    max-height: 46px;   /* 2 rangées × (20px + 3px gap) */
}
.ec-pill {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 10px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 2px 6px;
    white-space: nowrap;
    max-width: 150px;
    overflow: hidden;
}
.ec-pill span:first-child {
    overflow: hidden;
    text-overflow: ellipsis;
}
.ec-empty {
    font-size: 10px;
    color: var(--text-muted);
    font-style: italic;
}

/* Statut membres — 1 ligne fixe */
.ec-status {
    flex-shrink: 0;
    height: 16px;
    overflow: hidden;
    font-size: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
}

/* Actions */
.espace-card .card-actions {
    flex-shrink: 0;
    padding-top: 6px;
    margin-top: 0;
}

/* Modal membres */
.ec-member-badge {
    font-size: 10px;
    padding: 1px 7px;
    border-radius: 10px;
    font-weight: 600;
}
.ec-member-badge.join   { background:rgba(110,195,138,.15);color:#6ec38a;border:1px solid rgba(110,195,138,.3); }
.ec-member-badge.invite { background:rgba(201,161,60,.15);color:var(--gold);border:1px solid rgba(201,161,60,.3); }
.ec-member-badge.leave  { background:rgba(150,150,150,.1);color:var(--text-muted);border:1px solid var(--border); }
.ec-member-badge.ban    { background:rgba(192,57,43,.1);color:var(--red-light);border:1px solid rgba(192,57,43,.2); }
</style>
<script>
function espaceView() {
    return {
        espaces:        [],
        allSalons:      [],
        loading:        true,

        // Modal créer/modifier
        modalOpen:  false,
        modalMode:  'create',
        modalError: null,
        saving:     false,
        form:       { id: null, Nom: '', Description: '' },

        // Modal gérer salons
        addSalonTarget: null,
        addSalonSearch: '',
        addSalonError:  null,

        // Modal inviter
        inviteTarget:    null,
        inviteTab:       'personnel',   // 'personnel' | 'manual'
        inviteSearch:    '',
        inviteSelected:  [],            // IDs personnel sélectionnés
        inviteManual:    '',            // Matrix IDs manuels
        inviteError:     null,
        inviteSuccess:   null,
        personnel:       [],

        // Suppression
        deleteTarget: null,
        deleteError:  null,

        // Modal membres
        membersTarget:  null,
        membersLoading: false,
        membersError:   null,
        membersList:    [],

        // Initialise les propriétés réactives UI sur un objet espace brut
        _initEspace(e) {
            return { ...e, _loading: false, _error: null, _memberCount: null };
        },

        async load() {
            this.loading = true;
            try {
                const [espR, salR, perR] = await Promise.all([
                    apiFetch('/api/espaces'),
                    apiFetch('/api/salons'),
                    apiFetch('/api/personnel'),
                ]);
                // Initialiser les propriétés réactives AVANT de passer à Alpine
                this.espaces   = espR.map(e => this._initEspace(e));
                this.allSalons = salR;
                this.personnel = perR || [];
            } catch (e) {
                console.error(e);
            }
            this.loading = false;
        },

        // ── Créer / Modifier ──

        openModal(mode, espace = null) {
            this.modalMode  = mode;
            this.modalError = null;
            this.form       = espace
                ? { id: espace.id, Nom: espace.Nom, Description: espace.Description }
                : { id: null, Nom: '', Description: '' };
            this.modalOpen = true;
        },

        closeModal() {
            this.modalOpen = false;
        },

        async save() {
            this.modalError = null;
            if (!this.form.Nom.trim()) { this.modalError = 'Le nom est obligatoire'; return; }
            this.saving = true;
            try {
                const url    = this.modalMode === 'create' ? '/api/espaces' : `/api/espaces/${this.form.id}`;
                const method = this.modalMode === 'create' ? 'POST' : 'PATCH';
                const data   = await apiFetch(url, {
                    method,
                    body: JSON.stringify({ Nom: this.form.Nom, Description: this.form.Description }),
                });
                if (this.modalMode === 'create') {
                    this.espaces.push(this._initEspace(data));
                } else {
                    const idx = this.espaces.findIndex(e => e.id === data.id);
                    if (idx >= 0) this.espaces[idx] = { ...this.espaces[idx], ...data };
                }
                this.closeModal();
            } catch (e) {
                this.modalError = e.message;
            } finally {
                this.saving = false;
            }
        },

        // ── Créer sur Tchap ──

        async createTchapSpace(espace) {
            espace._loading = true;
            espace._error   = null;
            try {
                const data = await apiFetch(`/api/espaces/${espace.id}/create-space`, { method: 'POST' });
                // Mettre à jour les champs DB sans toucher aux propriétés réactives _*
                Object.keys(data).forEach(k => { if (!k.startsWith('_')) espace[k] = data[k]; });
                if (data._salons) espace._salons = data._salons;
                if (espace.space_id) toast(`Espace "${espace.Nom}" créé sur Tchap ✓`, 'success');
            } catch (e) {
                espace._error = e.message;
                toast(`Erreur création espace : ${e.message}`, 'error');
            } finally {
                espace._loading = false;
            }
        },

        // ── Gérer les salons ──

        openAddSalonModal(espace) {
            this.addSalonTarget = espace;
            this.addSalonSearch = '';
            this.addSalonError  = null;
        },

        closeAddSalonModal() {
            this.addSalonTarget = null;
        },

        availableSalons() {
            const linked = (this.addSalonTarget?._salons ?? []).map(s => s.id);
            return this.allSalons.filter(s =>
                !linked.includes(s.id) &&
                (!this.addSalonSearch || s.Nom.toLowerCase().includes(this.addSalonSearch.toLowerCase()))
            );
        },

        async doAddSalon(salon) {
            const espace = this.addSalonTarget;
            if (!espace) return;
            espace._loading    = true;
            this.addSalonError = null;
            try {
                const data = await apiFetch(`/api/espaces/${espace.id}/salons`, {
                    method: 'POST',
                    body: JSON.stringify({ salonId: salon.id }),
                });
                espace._salons = data._salons ?? espace._salons;
                if (data._tchap_warning) this.addSalonError = data._tchap_warning;
                // Feedback auto-invite
                if (data._invited > 0) {
                    toast(`${data._invited} membre(s) du salon invité(s) dans l'espace${data._skipped > 0 ? ` (${data._skipped} déjà présents)` : ''}`, 'success');
                }
            } catch (e) {
                this.addSalonError = e.message;
            } finally {
                espace._loading = false;
            }
        },

        async removeSalon(espace, salon) {
            espace._loading = true;
            espace._error   = null;
            try {
                const data = await apiFetch(`/api/espaces/${espace.id}/salons/${salon.id}`, { method: 'DELETE' });
                espace._salons = data._salons ?? espace._salons;
                if (data._tchap_warning) espace._error = data._tchap_warning;
            } catch (e) {
                espace._error = e.message;
            } finally {
                espace._loading = false;
            }
        },

        // ── Inviter ──

        openInviteModal(espace) {
            this.inviteTarget   = espace;
            this.inviteTab      = 'personnel';
            this.inviteSearch   = '';
            this.inviteSelected = [];
            this.inviteManual   = '';
            this.inviteError    = null;
            this.inviteSuccess  = null;
        },

        closeInviteModal() { this.inviteTarget = null; },

        get invitePersonnelFiltered() {
            const q = (this.inviteSearch || '').toLowerCase();
            return this.personnel.filter(p =>
                (p.user_id || p.Mail) &&
                (!q || `${p.Nom} ${p.Prenom} ${p.Grade || ''} ${p.Mail || ''}`.toLowerCase().includes(q))
            );
        },

        toggleInvitePerson(id) {
            if (this.inviteSelected.includes(id))
                this.inviteSelected = this.inviteSelected.filter(x => x !== id);
            else
                this.inviteSelected = [...this.inviteSelected, id];
        },

        async doInvite() {
            this.inviteError   = null;
            this.inviteSuccess = null;

            // Construire la liste des Matrix IDs à inviter
            const userIds = [];

            if (this.inviteTab === 'personnel') {
                for (const id of this.inviteSelected) {
                    const p = this.personnel.find(x => x.id === id);
                    if (!p) continue;
                    const uid = p.user_id || (p.Mail ? mailToTchapId(p.Mail) : null);
                    if (uid) userIds.push(uid);
                }
            } else {
                // Manuel : une entrée par ligne, email ou Matrix ID
                for (const line of this.inviteManual.split('\n').map(l => l.trim()).filter(Boolean)) {
                    if (line.startsWith('@') && line.includes(':')) userIds.push(line);
                    else if (line.includes('@') && !line.startsWith('@')) userIds.push(mailToTchapId(line));
                }
            }

            if (!userIds.length) { this.inviteError = 'Aucun identifiant valide sélectionné'; return; }

            this.saving = true;
            let ok = 0;
            const errors = [];
            for (const userId of userIds) {
                try {
                    await apiFetch(`/api/espaces/${this.inviteTarget.id}/invite`, {
                        method: 'POST',
                        body: JSON.stringify({ userId }),
                    });
                    ok++;
                } catch (e) {
                    errors.push(`${userId} : ${e.message}`);
                }
            }
            this.inviteSuccess = ok > 0 ? `✓ ${ok} membre(s) invité(s) dans l'espace` : null;
            this.inviteError   = errors.length ? errors.join('\n') : null;
            if (ok > 0) {
                this.inviteSelected = [];
                this.inviteManual   = '';
            }
            this.saving = false;
        },

        // ── Modal membres ──

        async openMembersModal(espace) {
            this.membersTarget  = espace;
            this.membersLoading = true;
            this.membersError   = null;
            this.membersList    = [];
            try {
                const data = await apiFetch(`/api/espaces/${espace.id}/members`);
                this.membersList = data.members ?? [];
                // Mettre à jour le compteur sur la vignette
                espace._memberCount = {
                    joined:  this.membersList.filter(m => m.membership === 'join').length,
                    invited: this.membersList.filter(m => m.membership === 'invite').length,
                };
            } catch (e) {
                this.membersError = e.message;
            } finally {
                this.membersLoading = false;
            }
        },

        async syncMembers(espace) {
            espace._loading = true;
            try {
                const data = await apiFetch(`/api/espaces/${espace.id}/sync-members`, { method: 'POST' });
                const msg = `${data.invited} invité(s)${data.skipped > 0 ? `, ${data.skipped} déjà présents` : ''}`;
                toast(data.invited > 0 ? msg : `Tous les membres sont déjà dans l'espace`, data.invited > 0 ? 'success' : 'info');
                if (data.errors?.length) data.errors.forEach(e => toast(e, 'error'));
                // Rafraîchir le compteur si la modale est ouverte sur cet espace
                if (this.membersTarget?.id === espace.id) await this.openMembersModal(espace);
            } catch (e) {
                toast(e.message, 'error');
            } finally {
                espace._loading = false;
            }
        },

        closeMembersModal() {
            this.membersTarget = null;
            this.membersList   = [];
            this.membersError  = null;
        },

        // ── Suppression ──

        startDelete(espace) {
            this.deleteTarget = espace;
            this.deleteError  = null;
        },

        cancelDelete() {
            this.deleteTarget = null;
        },

        async doDelete() {
            this.deleteError = null;
            this.saving      = true;
            try {
                if (this.deleteTarget.space_id) {
                    await apiFetch(`/api/salons/${encodeURIComponent(this.deleteTarget.space_id)}/leave`, { method: 'POST' })
                        .catch(() => {});
                }
                await apiFetch(`/api/espaces/${this.deleteTarget.id}`, { method: 'DELETE' });
                this.espaces      = this.espaces.filter(e => e.id !== this.deleteTarget.id);
                this.deleteTarget = null;
            } catch (e) {
                this.deleteError = e.message;
            } finally {
                this.saving = false;
            }
        },
    };
}
</script>
{% endblock %}
