        },
        // Fin
        {
            id: 'end',
            roles: ['gestionnaire', 'superviseur_crise', 'admin', 'sysadmin'],
            icon: 'fa-solid fa-circle-check',
            bg: 'rgba(110,195,138,.12)',
            color: '#6ec38a',
            title: 'Vous êtes prêt·e !',
            desc: `La visite est terminée. Vous pouvez la relancer à tout moment
                   depuis ce tableau de bord.
                   <br><br>
                   En cas de question, consultez la documentation ou contactez
                   votre administrateur.`,
            url: null,
        },
    ];

    // Filtrer les étapes selon le rôle
    const baseRole = role.includes(':') ? role.split(':')[0] : role;
    const tourSteps = ALL_STEPS.filter(s => s.roles.includes(baseRole));

    return {
        tourOpen:    false,
        currentStep: 0,
        tourSteps,

        init() {
            // Auto-lancer la visite à la première connexion
            const seen = localStorage.getItem('bv_tour_done_v1');
            if (!seen) {
                setTimeout(() => this.startTour(), 600);
            }
        },

        startTour() {
            this.currentStep = 0;
            this.tourOpen    = true;
        },

        nextStep() {
            if (this.currentStep < this.tourSteps.length - 1) {
                this.currentStep++;
            } else {
                this.closeTour();
            }
        },

        prevStep() {
            if (this.currentStep > 0) this.currentStep--;
        },

        closeTour() {
            this.tourOpen = false;
            localStorage.setItem('bv_tour_done_v1', '1');
        },
    };
}

function auditDroits() {
    return {
        loading: false,
        loaded:  false,
        data:    {},
        openGroup: null,
        groups: [
            {
                key:   'admins',
                label: 'Administrateurs',
                icon:  'fa-solid fa-shield-halved',
                bg:    'rgba(45,108,223,.12)',
                color: 'var(--blue-light)',
            },
            {
                key:   'superviseurs',
                label: 'Superviseurs de crise',
                icon:  'fa-solid fa-triangle-exclamation',
                bg:    'rgba(192,57,43,.12)',
                color: 'var(--red-light)',
            },
            {
                key:   'gestionnaires',
                label: 'Gestionnaires',
                icon:  'fa-solid fa-user-gear',
                bg:    'rgba(110,195,138,.12)',
                color: '#6ec38a',
            },
        ],

        async toggle(key) {
            if (this.openGroup === key) { this.openGroup = null; return; }
            this.openGroup = key;
            if (!this.loaded) await this.load();
        },

        async load() {
            this.loading = true;
            try {
                const r = await fetch('/api/audit/droits');
                this.data   = await r.json();
                this.loaded = true;
            } catch (e) {
                console.error('Audit droits:', e);
            } finally {
                this.loading = false;
            }
        },
    };
}
</script>
