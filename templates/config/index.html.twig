{% extends 'base.html.twig' %}

{% block title %}Configuration — Gestion Tchap{% endblock %}

{% block content %}
<div class="view" x-data="configView()" x-init="load()">

    {# ── Toolbar ── #}
    <div class="view-toolbar">
        <div class="toolbar-left">
            <span class="view-title">CONFIGURATION</span>
        </div>
    </div>

    {# ── Contenu ── #}
    <div id="config-content">
        <div class="config-grid">

            {# ── Connexion Tchap (paramètres globaux) ── #}
            <div class="config-section">
                <div class="config-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.49 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.4 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.4a16 16 0 0 0 6.69 6.69l1.48-1.74a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                    Connexion Tchap / Matrix
                </div>
                <div class="config-form">
                    <div class="form-group">
                        <label>Homeserver URL <small style="color:var(--text-muted);font-weight:400;">(utilisé par défaut pour tous les bots)</small></label>
                        <input type="text" x-model="tchapConfig.homeserver"
                            placeholder="https://matrix.agent.interieur.tchap.gouv.fr">
                    </div>

                    {# Intégration active #}
                    <div class="form-group" style="flex-direction:row;align-items:center;gap:10px;">
                        <label style="margin:0;">Intégration active</label>
                        <input type="checkbox" x-model="tchapConfig.enabled"
                            style="width:16px;height:16px;accent-color:var(--blue-light);">
                    </div>

                    {# Résultat test #}
                    <div style="font-size:12px;padding:6px 0;min-height:18px;"
                        :style="{ color: cfgTestColor }" x-text="cfgTestResult"></div>

                    <div style="display:flex;gap:10px;margin-top:4px;">
                        <button class="btn-ghost" @click="testConnection()">Tester la connexion</button>
                        <button class="btn-primary" @click="saveTchapConfig()">
                            <i class="fa-solid fa-floppy-disk"></i> Enregistrer
                        </button>
                    </div>
                </div>
            </div>

            {# ── Serveurs Tchap connus ── #}
            <div class="config-section">
                <div class="config-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                    </svg>
                    Serveurs Tchap connus
                </div>
                <p style="font-size:12px;color:var(--text-secondary);margin-bottom:12px;line-height:1.6;">
                    Chaque entrée associe des domaines email à un <strong>serveur d'accueil</strong> (homeserver Matrix) et optionnellement un <strong>serveur d'identité</strong>.
                    Utilisé pour convertir automatiquement les emails en identifiants Matrix multi-administration.
                </p>

                {# Liste des serveurs #}
                <div style="margin-bottom:12px;">
                    <template x-for="(srv, idx) in tchapServers" :key="srv.id">
                        <div style="padding:10px 12px;margin-bottom:6px;background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-sm);">
                            <div style="display:flex;align-items:flex-start;gap:10px;">
                                <div style="flex:1;min-width:0;">
                                    <div style="font-size:13px;font-weight:700;margin-bottom:3px;" x-text="srv.name"></div>
                                    <div style="font-size:11px;color:var(--text-muted);margin-bottom:3px;">
                                        <span style="font-weight:600;color:var(--text-secondary);">Domaines :</span>
                                        <span style="font-family:monospace;" x-text="srv.domains"></span>
                                    </div>
                                    <div style="font-size:11px;color:var(--text-muted);margin-bottom:2px;">
                                        <span style="font-weight:600;color:var(--text-secondary);">Serveur d'accueil :</span>
                                        <span style="font-family:monospace;color:var(--blue-light);" x-text="srv.homeserver"></span>
                                    </div>
                                    <div x-show="srv.identityServer" style="font-size:11px;color:var(--text-muted);">
                                        <span style="font-weight:600;color:var(--text-secondary);">Serveur d'identité :</span>
                                        <span style="font-family:monospace;" x-text="srv.identityServer"></span>
                                    </div>
                                </div>
                                <div style="display:flex;gap:4px;flex-shrink:0;">
                                    <button class="btn-ghost" style="font-size:11px;padding:3px 8px;" @click="openServerForm(srv, idx)">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <button class="btn-icon" style="color:var(--red-light);" @click="deleteServer(idx)">
                                        <i class="fa-solid fa-trash" style="font-size:11px;"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </template>
                    <div x-show="tchapServers.length === 0" style="font-size:12px;color:var(--text-muted);padding:8px 0;">Aucun serveur configuré.</div>
                </div>

                {# Formulaire ajout / édition #}
                <template x-if="serverFormOpen">
                    <div style="border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;background:var(--bg-elevated);margin-bottom:12px;">
                        <div style="font-size:12px;font-weight:700;color:var(--text-primary);margin-bottom:12px;"
                            x-text="serverFormIdx !== null ? 'Modifier le serveur' : 'Ajouter un serveur'"></div>
                        <div class="form-grid">
                            <div class="form-group form-full" style="margin:0;">
                                <label>Nom *</label>
                                <input type="text" x-model="serverForm.name" placeholder="Ex: Ministère des Affaires étrangères" autocomplete="off">
                            </div>
                            <div class="form-group form-full" style="margin:0;">
                                <label>
                                    Domaines email *
                                    <small style="font-weight:400;color:var(--text-muted);">séparés par virgule</small>
                                </label>
                                <input type="text" x-model="serverForm.domains"
                                    placeholder="diplomatie.gouv.fr, consulat.diplomatie.gouv.fr"
                                    style="font-family:monospace;font-size:12px;" autocomplete="off">
                            </div>
                            <div class="form-group form-full" style="margin:0;">
                                <label>
                                    Serveur d'accueil *
                                    <small style="font-weight:400;color:var(--text-muted);">URL du homeserver Matrix</small>
                                </label>
                                <input type="text" x-model="serverForm.homeserver"
                                    placeholder="https://matrix.agent.diplomatie.tchap.gouv.fr"
                                    style="font-family:monospace;font-size:12px;" autocomplete="off">
                                <small x-show="serverForm.homeserver" style="color:var(--text-muted);margin-top:3px;display:block;">
                                    ID Matrix généré :
                                    <code style="color:var(--gold);">@prenom.nom-domaine.gouv.fr:<span x-text="(() => { try { const h = new URL(serverForm.homeserver).hostname; return h.startsWith('matrix.') ? h.slice(7) : h; } catch(_){return '?'} })()"></span></code>
                                </small>
                            </div>
                            <div class="form-group form-full" style="margin:0;">
                                <label>
                                    Serveur d'identité
                                    <small style="font-weight:400;color:var(--text-muted);">optionnel — pour la résolution email ↔ Matrix ID</small>
                                </label>
                                <input type="text" x-model="serverForm.identityServer"
                                    placeholder="https://matrix.tchap.gouv.fr"
                                    style="font-family:monospace;font-size:12px;" autocomplete="off">
                            </div>
                        </div>
                        <div x-show="serverFormError" class="alert-error" x-text="serverFormError" style="margin-top:10px;margin-bottom:4px;"></div>
                        <div style="display:flex;gap:8px;margin-top:12px;">
                            <button class="btn-primary" @click="saveServerForm()">
                                <i class="fa-solid fa-floppy-disk"></i>
                                <span x-text="serverFormIdx !== null ? 'Mettre à jour' : 'Ajouter'"></span>
                            </button>
                            <button class="btn-ghost" @click="closeServerForm()">Annuler</button>
                        </div>
                    </div>
                </template>

                <button class="btn-ghost" style="font-size:12px;width:100%;justify-content:center;border-style:dashed;"
                    @click="openServerForm()" x-show="!serverFormOpen">
                    <i class="fa-solid fa-plus"></i> Ajouter un serveur
                </button>
            </div>

            {# ── Gestion des bots ── #}
            {% if permissions.canAdmin %}
            <div class="config-section">
                <div class="config-section-title">
                    <i class="fa-solid fa-robot" style="font-size:14px;"></i>
                    Bots Matrix
                </div>

                {# Liste des bots #}
                <div style="margin-bottom:12px;">
                    <template x-if="bots.length === 0">
                        <div style="font-size:12px;color:var(--text-muted);padding:8px 0;">Aucun bot configuré. Ajoutez-en un ci-dessous.</div>
                    </template>
                    <template x-for="bot in bots" :key="bot.id">
                        <div style="display:flex;align-items:center;gap:10px;padding:10px 12px;margin-bottom:6px;background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-sm);">
                            {# Statut connexion #}
                            <div style="flex-shrink:0;">
                                <span :style="{ color: bot.connected ? '#6ec38a' : 'var(--red-light)' }" style="font-size:18px;">
                                    <i :class="bot.connected ? 'fa-solid fa-circle-check' : 'fa-solid fa-circle-xmark'"></i>
                                </span>
                            </div>
                            {# Infos #}
                            <div style="flex:1;min-width:0;">
                                <div style="display:flex;align-items:center;gap:8px;margin-bottom:3px;">
                                    <span style="font-size:13px;font-weight:700;" x-text="bot.name"></span>
                                    <span style="font-size:10px;padding:1px 7px;border-radius:3px;font-weight:600;"
                                        :style="bot.isPrincipal ? 'background:rgba(201,168,76,.15);color:var(--gold);border:1px solid rgba(201,168,76,.3)' : 'background:rgba(45,108,223,.1);color:var(--blue-light);border:1px solid rgba(45,108,223,.25)'"
                                        x-text="bot.isPrincipal ? 'Principal' : 'Secondaire'"></span>
                                </div>
                                <div style="font-size:11px;color:var(--text-muted);font-family:monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" x-text="bot.userId"></div>
                                <div x-show="bot.homeserver" style="font-size:10px;color:var(--text-muted);margin-top:2px;" x-text="bot.homeserver"></div>
                            </div>
                            {# Actions #}
                            <div style="display:flex;gap:6px;flex-shrink:0;align-items:center;">
                                <template x-if="bot.connected">
                                    <button class="btn-ghost" style="font-size:11px;padding:4px 10px;color:var(--red-light);border-color:var(--red-light);" @click="doLogoutBot(bot)">
                                        <i class="fa-solid fa-plug-circle-xmark"></i> Déconnecter
                                    </button>
                                </template>
                                <template x-if="!bot.connected">
                                    <button class="btn-ghost" style="font-size:11px;padding:4px 10px;color:#6ec38a;border-color:#6ec38a;"
                                        @click="openBotLogin(bot.id)">
                                        <i class="fa-solid fa-plug"></i> Connecter
                                    </button>
                                </template>
                                <button class="btn-ghost" style="font-size:11px;padding:4px 10px;" @click="openBotForm(bot)">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <button class="btn-icon" style="color:var(--red-light);" @click="deleteBot(bot)">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </template>
                </div>

                {# Formulaire connexion d'un bot #}
                <template x-if="loginBotId !== null">
                    <div style="background:rgba(110,195,138,.06);border:1px solid rgba(110,195,138,.25);border-radius:var(--radius-sm);padding:14px;margin-bottom:12px;">
                        <div style="font-size:12px;font-weight:700;color:#6ec38a;margin-bottom:10px;">
                            <i class="fa-solid fa-plug"></i>
                            Connexion — <span x-text="bots.find(b => b.id === loginBotId)?.name"></span>
                        </div>
                        <div style="font-size:11px;color:var(--text-muted);margin-bottom:8px;">
                            Le mot de passe n'est jamais stocké. Seul le token de session est conservé.
                        </div>
                        <div style="display:flex;gap:8px;align-items:flex-end;">
                            <div style="flex:1;">
                                <input type="password" x-model="loginBotPassword"
                                    placeholder="Mot de passe du bot"
                                    @keyup.enter="doLoginBot(bots.find(b => b.id === loginBotId))"
                                    style="width:100%;" autocomplete="new-password">
                            </div>
                            <button class="btn-primary" style="flex-shrink:0;"
                                :disabled="loginBotLoading || !loginBotPassword.trim()"
                                @click="doLoginBot(bots.find(b => b.id === loginBotId))">
                                <i x-show="loginBotLoading" class="fa-solid fa-spinner fa-spin"></i>
                                <span x-show="!loginBotLoading"><i class="fa-solid fa-right-to-bracket"></i> Se connecter</span>
                            </button>
                            <button class="btn-ghost" @click="closeBotLogin()">Annuler</button>
                        </div>
                        <div x-show="loginBotError" class="alert-error" x-text="loginBotError" style="margin-top:8px;font-size:12px;"></div>
                    </div>
                </template>

                {# Formulaire ajout/édition d'un bot #}
                <template x-if="botFormOpen">
                    <div style="border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;background:var(--bg-elevated);margin-bottom:12px;">
                        <div style="font-size:12px;font-weight:700;color:var(--text-primary);margin-bottom:12px;"
                            x-text="botForm.id ? 'Modifier le bot' : 'Ajouter un bot'"></div>
                        <div class="form-grid">
                            <div class="form-group" style="margin:0;">
                                <label>Nom *</label>
                                <input type="text" x-model="botForm.name" placeholder="Ex: Bot Principal" autocomplete="off">
                            </div>
                            <div class="form-group" style="margin:0;">
                                <label>User ID Matrix *</label>
                                <input type="text" x-model="botForm.userId"
                                    placeholder="@bot-gestion:agent.interieur.tchap.gouv.fr" autocomplete="off">
                            </div>
                            <div class="form-group" style="margin:0;">
                                <label>Homeserver <small style="color:var(--text-muted);">(optionnel, utilise le global par défaut)</small></label>
                                <input type="text" x-model="botForm.homeserver"
                                    placeholder="https://matrix.agent.interieur.tchap.gouv.fr" autocomplete="off">
                            </div>
                            <div class="form-group" style="margin:0;flex-direction:row;align-items:center;gap:10px;padding-top:20px;">
                                <label style="margin:0;">Bot principal</label>
                                <input type="checkbox" x-model="botForm.isPrincipal"
                                    style="width:16px;height:16px;accent-color:var(--gold);">
                                <small style="color:var(--text-muted);">(gère E2EE via le bridge)</small>
                            </div>
                        </div>
                        <div x-show="botFormError" class="alert-error" x-text="botFormError" style="margin-top:10px;margin-bottom:4px;"></div>
                        <div style="display:flex;gap:8px;margin-top:12px;">
                            <button class="btn-primary" @click="saveBotForm()">
                                <i class="fa-solid fa-floppy-disk"></i>
                                <span x-text="botForm.id ? 'Mettre à jour' : 'Ajouter'"></span>
                            </button>
                            <button class="btn-ghost" @click="closeBotForm()">Annuler</button>
                        </div>
                    </div>
                </template>

                {# Bouton ajouter #}
                <button class="btn-ghost" style="font-size:12px;width:100%;justify-content:center;border-style:dashed;"
                    @click="openBotForm()" x-show="!botFormOpen">
                    <i class="fa-solid fa-plus"></i> Ajouter un bot
                </button>
            </div>
            {% endif %}

            {# ── Réconciliation Tchap ── #}
            <div class="config-section">
                <div class="config-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    Réconciliation user_id Tchap
                </div>
                <div style="font-size:12px;color:var(--text-secondary);margin-bottom:12px;line-height:1.6;">
                    <p>Analyse les membres présents dans les salons Tchap et les relie automatiquement aux agents en comparant les adresses email.</p>
                    <p style="margin-top:6px;color:var(--text-muted);font-size:11px;">Domaines email acceptés (séparés par virgule) :</p>
                    <div style="display:flex;gap:8px;margin-top:4px;">
                        <input type="text" x-model="tchapConfig.emailDomains"
                            placeholder="gendarmerie.interieur.gouv.fr, police.interieur.gouv.fr"
                            style="flex:1;font-size:11px;">
                        <button class="btn-ghost" style="font-size:11px;padding:6px 12px;flex-shrink:0;"
                            @click="saveEmailDomains()">Sauver</button>
                    </div>
                </div>
                <button class="btn-primary" @click="runReconciliation()" :disabled="reconRunning" style="margin-bottom:14px;">
                    <i x-show="reconRunning" class="fa-solid fa-spinner fa-spin" style="margin-right:6px;"></i>
                    <span x-text="reconRunning ? 'Analyse en cours…' : (reconDone ? 'Relancer l\'analyse' : 'Lancer l\'analyse')"></span>
                </button>
                <div x-show="reconResults" style="font-size:12px;" x-html="reconResults"></div>
            </div>

            {# ── Chiffrement E2EE (mode bridge) ── #}
            <div class="config-section">
                <div class="config-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        <circle cx="12" cy="16" r="1" fill="currentColor"/>
                    </svg>
                    Chiffrement E2EE
                </div>

                {# Statut bridge #}
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
                    <div style="display:flex;align-items:center;gap:8px;flex:1;">
                        <i x-show="e2eePhase === 'starting'" class="fa-solid fa-spinner fa-spin" style="font-size:12px;flex-shrink:0;"></i>
                        <span style="font-size:12px;font-weight:600;"
                            :style="{ color: e2eePhase === 'ready' ? '#6ec38a' : e2eePhase === 'error' ? 'var(--red-light)' : 'var(--text-muted)' }">
                            <span x-show="e2eePhase === 'idle'">⬤ Bridge non connecté — configurez le bot via <em>Se connecter</em></span>
                            <span x-show="e2eePhase === 'starting'" x-text="e2eeMessage || 'Vérification…'"></span>
                            <span x-show="e2eePhase === 'ready'">✓ E2EE actif — géré automatiquement par le bridge</span>
                            <span x-show="e2eePhase === 'error'">✗ <span x-text="e2eeError"></span></span>
                        </span>
                    </div>
                    <button class="btn-ghost" style="font-size:11px;padding:4px 12px;flex-shrink:0;"
                        :disabled="e2eePhase === 'starting'"
                        @click="startE2EE()">
                        <i x-show="e2eePhase === 'starting'" class="fa-solid fa-spinner fa-spin" style="margin-right:4px;"></i>
                        <span x-text="e2eePhase === 'starting' ? 'Vérification…' : 'Vérifier l\'état'"></span>
                    </button>
                </div>

                {# Explication mode bridge #}
                <div style="padding:10px 14px;background:rgba(45,108,223,.05);border:1px solid rgba(45,108,223,.2);border-radius:var(--radius-sm);font-size:12px;color:var(--text-secondary);line-height:1.7;">
                    <p><strong style="color:var(--blue-light);">Mode bridge actif</strong> — le chiffrement E2EE est pris en charge par le service <code>tchap-bridge</code> (RustSdkCryptoStorageProvider).</p>
                    <p style="margin-top:6px;">Les clés sont stockées dans le volume Docker <code>tchap_data</code> et persistent entre les redémarrages.</p>
                </div>

                {# Reset clés (dernier recours) #}
                <details style="margin-top:14px;">
                    <summary style="font-size:11px;color:var(--text-muted);cursor:pointer;user-select:none;">
                        Réinitialiser les clés E2EE (dernier recours)
                    </summary>
                    <div style="margin-top:10px;padding:10px 14px;background:rgba(192,57,43,.07);border:1px solid rgba(192,57,43,.25);border-radius:var(--radius-sm);">
                        <p style="font-size:11px;color:var(--red-light);font-weight:600;margin-bottom:6px;">⚠ Action irréversible</p>
                        <p style="font-size:11px;color:var(--text-secondary);line-height:1.6;margin-bottom:10px;">
                            Supprime le volume crypto du bridge et régénère les clés Rust SDK.
                            Le device ne sera <strong>plus reconnu</strong> par les pairs Tchap.<br>
                            Exécutez sur le serveur :
                        </p>
                        <code style="display:block;font-size:11px;padding:8px 10px;background:var(--bg-base);border-radius:var(--radius-sm);color:var(--gold);line-height:1.8;user-select:all;">
                            docker compose stop tchap-bridge<br>
                            docker volume rm $(docker compose config --volumes | grep tchap_data)<br>
                            docker compose up -d tchap-bridge
                        </code>
                    </div>
                </details>

                {# ── Import de clés Megolm ── #}
                {% if permissions.canAdmin %}
                <details style="margin-top:14px;">
                    <summary style="font-size:11px;color:var(--text-muted);cursor:pointer;user-select:none;">
                        Importer un fichier de clés Megolm (<code>tchap-keys.txt</code>)
                    </summary>
                    <div style="margin-top:10px;padding:10px 14px;background:rgba(45,108,223,.05);border:1px solid rgba(45,108,223,.2);border-radius:var(--radius-sm);">
                        <p style="font-size:11px;color:var(--text-secondary);line-height:1.6;margin-bottom:10px;">
                            Permet au bot de déchiffrer des messages historiques en important les clés de sessions Megolm
                            exportées depuis votre application Tchap/Element
                            (<strong>Paramètres → Sécurité → Exporter les clés E2EE</strong>).
                        </p>
                        <div style="display:flex;flex-direction:column;gap:8px;">
                            <label style="display:block;cursor:pointer;border:1px dashed rgba(45,108,223,.4);border-radius:4px;padding:8px 12px;font-size:12px;text-align:center;color:var(--text-muted);transition:border-color .15s;"
                                :style="keyFileContent ? 'border-color:rgba(45,108,223,.8);color:var(--blue-light);' : ''"
                                @dragover.prevent @drop.prevent="onKeyFileChange({target:{files:$event.dataTransfer.files}})">
                                <i class="fa-solid fa-file-arrow-up" style="margin-right:5px;"></i>
                                <span x-text="keyFileContent ? '✓ Fichier chargé' : 'Choisir tchap-keys.txt (ou glisser-déposer)'"></span>
                                <input type="file" accept=".txt" style="display:none;" @change="onKeyFileChange($event)">
                            </label>
                            <div style="display:flex;gap:8px;align-items:center;">
                                <input :type="showKeyPassphrase ? 'text' : 'password'"
                                    x-model="keyPassphrase"
                                    placeholder="Passphrase utilisée lors de l'export"
                                    style="flex:1;font-size:12px;" autocomplete="off">
                                <button class="btn-ghost" style="font-size:11px;padding:4px 8px;flex-shrink:0;"
                                    @click="showKeyPassphrase = !showKeyPassphrase"
                                    :title="showKeyPassphrase ? 'Masquer' : 'Afficher'">
                                    <i :class="showKeyPassphrase ? 'fa-solid fa-eye-slash' : 'fa-solid fa-eye'"></i>
                                </button>
                                <button class="btn-primary" style="font-size:11px;padding:6px 12px;flex-shrink:0;"
                                    :disabled="keyImportLoading || !keyFileContent || !keyPassphrase.trim()"
                                    @click="doImportKeys()">
                                    <i x-show="keyImportLoading" class="fa-solid fa-spinner fa-spin"></i>
                                    <span x-show="!keyImportLoading"><i class="fa-solid fa-key"></i> Importer</span>
                                </button>
                            </div>
                            <div x-show="keyImportResult" style="font-size:11px;padding:6px 10px;border-radius:3px;background:var(--bg-elevated);"
                                :style="{ color: keyImportResultColor }" x-text="keyImportResult"></div>
                        </div>
                    </div>
                </details>
                {% endif %}

                {# ── Vérification SAS ── #}
                {% if permissions.isSysAdmin %}
                <div style="margin-top:18px;padding-top:14px;border-top:1px solid var(--border);">
                    <div style="font-size:12px;font-weight:700;color:var(--text-primary);margin-bottom:10px;">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:5px;">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                        Vérification SAS de l'appareil bot
                    </div>

                    {# Étape 1 — idle : instructions + bouton de vérification #}
                    <div x-show="!verifState || verifState === 'idle'">
                        <ol style="font-size:12px;color:var(--text-secondary);line-height:1.8;margin:0 0 12px 16px;padding:0;">
                            <li>Dans <strong>Tchap</strong> : ouvrez le profil du bot → <strong>Vérifier l'appareil</strong></li>
                            <li>Revenez ici et cliquez sur <strong>Vérifier l'état</strong></li>
                            <li>Comparez les emojis affichés des deux côtés</li>
                        </ol>
                        <button class="btn-ghost" style="font-size:11px;padding:5px 12px;"
                            @click="acceptVerif()">
                            <i class="fa-solid fa-rotate" style="margin-right:5px;"></i>Vérifier l'état
                        </button>
                    </div>

                    {# Vérification en cours — échange de clés (bridge auto-accepte) #}
                    <div x-show="['accepting','requested','accepted','started','key-sent'].includes(verifState)"
                         style="font-size:12px;color:var(--text-muted);display:flex;align-items:center;gap:8px;">
                        <i class="fa-solid fa-spinner fa-spin"></i>
                        <span>Échange de clés en cours<template x-if="verifUserId"> — demande de <strong x-text="verifUserId"></strong></template>…</span>
                        <button class="btn-ghost" style="margin-left:auto;font-size:11px;padding:3px 8px;" @click="cancelVerif()">Annuler</button>
                    </div>

                    {# Étape 2 — emojis à comparer #}
                    <div x-show="verifState === 'sas'">
                        <p style="font-size:12px;font-weight:600;color:var(--text-primary);margin-bottom:10px;">
                            Comparez ces 7 emojis avec ceux affichés dans Tchap :
                        </p>
                        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:14px;">
                            <template x-for="e in verifEmoji" :key="e.label">
                                <div style="text-align:center;min-width:48px;">
                                    <div style="font-size:28px;" x-text="e.emoji"></div>
                                    <div style="font-size:10px;color:var(--text-muted);margin-top:3px;" x-text="e.label"></div>
                                </div>
                            </template>
                        </div>
                        <p style="font-size:11px;color:var(--text-muted);margin-bottom:10px;">Ils correspondent exactement dans Tchap ?</p>
                        <div style="display:flex;gap:8px;">
                            <button class="btn-primary" style="font-size:12px;background:#27ae60;border-color:#27ae60;" @click="confirmVerif()">
                                <i class="fa-solid fa-check"></i> Oui, identiques
                            </button>
                            <button class="btn-ghost" style="font-size:12px;color:var(--red-light);border-color:var(--red-light);" @click="mismatchVerif()">
                                <i class="fa-solid fa-xmark"></i> Non, annuler
                            </button>
                        </div>
                    </div>

                    {# Confirmation en cours #}
                    <div x-show="verifState === 'confirming'"
                         style="font-size:12px;color:var(--text-muted);display:flex;align-items:center;gap:8px;">
                        <i class="fa-solid fa-spinner fa-spin"></i> Envoi de la confirmation…
                    </div>

                    {# Succès #}
                    <div x-show="['mac-sent','done'].includes(verifState)"
                         style="font-size:12px;color:#6ec38a;display:flex;align-items:center;gap:8px;padding:10px 12px;background:rgba(110,195,138,.08);border:1px solid rgba(110,195,138,.25);border-radius:var(--radius-sm);">
                        <i class="fa-solid fa-circle-check"></i>
                        Vérification SAS terminée — l'appareil bot est maintenant authentifié.
                        <button class="btn-ghost" style="margin-left:auto;font-size:11px;" @click="verifState = null">OK</button>
                    </div>

                    {# Erreur #}
                    <div x-show="verifState === 'error'"
                         style="font-size:12px;color:var(--red-light);padding:10px 12px;background:rgba(192,57,43,.07);border:1px solid rgba(192,57,43,.25);border-radius:var(--radius-sm);">
                        <span x-text="'✗ ' + (verifError || 'Erreur inconnue')"></span>
                        <button class="btn-ghost" style="margin-left:8px;font-size:11px;" @click="verifState = null">Réessayer</button>
                    </div>

                    {# ── Vérification par clé de sécurité (alternative au SAS) ── #}
                    <div style="margin-top:14px;padding-top:14px;border-top:1px dashed var(--border);">
                        <div style="font-size:11px;font-weight:600;color:var(--text-secondary);margin-bottom:8px;display:flex;align-items:center;gap:6px;">
                            <i class="fa-solid fa-key" style="opacity:.7;"></i>
                            Alternative : vérifier via la clé de sécurité du compte bot
                        </div>
                        <p style="font-size:11px;color:var(--text-muted);margin-bottom:10px;line-height:1.6;">
                            Entrez les 12 groupes de 4 caractères affichés dans
                            <strong>Tchap → Clés Tchap → Changer le code de vérification</strong>.
                        </p>
                        <div style="display:flex;gap:8px;align-items:stretch;">
                            <input
                                type="text"
                                x-model="verifKeyInput"
                                placeholder="xxxx xxxx xxxx xxxx xxxx xxxx xxxx xxxx xxxx xxxx xxxx xxxx"
                                style="flex:1;font-size:11px;font-family:monospace;padding:6px 10px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--bg-input, var(--bg));color:var(--text-primary);"
                                :disabled="verifKeyLoading"
                                @keydown.enter="verifyWithKey()"
                            >
                            <button class="btn-primary" style="font-size:11px;padding:5px 12px;white-space:nowrap;"
                                :disabled="verifKeyLoading || !verifKeyInput.trim()"
                                @click="verifyWithKey()">
                                <i class="fa-solid fa-spinner fa-spin" x-show="verifKeyLoading" style="margin-right:4px;"></i>
                                <i class="fa-solid fa-shield-halved" x-show="!verifKeyLoading" style="margin-right:4px;"></i>
                                Vérifier
                            </button>
                        </div>
                        <div x-show="verifError && !verifState"
                             style="margin-top:6px;font-size:11px;color:var(--red-light);"
                             x-text="'✗ ' + verifError"></div>
                    </div>
                </div>
                {% endif %}
            </div>

            {# ── Visibilité des fonctionnalités ── #}
            <div class="config-section config-section-full">
                <div class="config-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                        <circle cx="12" cy="12" r="3"/>
                    </svg>
                    Visibilité des fonctionnalités
                </div>
                <div style="font-size:12px;color:var(--text-secondary);margin-bottom:14px;line-height:1.6;">
                    Définissez quelles fonctionnalités sont accessibles à chaque profil.
                </div>
                <div style="overflow:auto;">
                    <table class="data-table" style="width:100%;">
                        <thead>
                            <tr>
                                <th>Rôle</th>
                                <th style="text-align:center;">Cartographie</th>
                                <th style="text-align:center;">Mode Crise</th>
                                <th style="text-align:center;">Suivi Crise</th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="role in ['lecteur','gestionnaire','superviseur_crise','admin']" :key="role">
                                <tr>
                                    <td>
                                        <span class="user-role-badge" :class="'role-' + role" x-text="roleLabel(role)"></span>
                                    </td>
                                    <template x-for="feat in ['carto','crise','suivi_crise']" :key="feat">
                                        <td style="text-align:center;">
                                            <input type="checkbox"
                                                :checked="uiConfig.roleFeatures && uiConfig.roleFeatures[role] && uiConfig.roleFeatures[role][feat]"
                                                @change="toggleRoleFeature(role, feat, $event.target.checked)"
                                                :disabled="role === 'admin'"
                                                style="width:15px;height:15px;accent-color:var(--gold);cursor:pointer;">
                                        </td>
                                    </template>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
                <div style="margin-top:12px;display:flex;gap:10px;align-items:center;">
                    <button class="btn-primary" @click="saveUiConfig()">
                        <i class="fa-solid fa-floppy-disk"></i> Enregistrer
                    </button>
                    <span x-show="featureSaved" style="font-size:12px;color:#6ec38a;">✓ Sauvegardé</span>
                </div>
            </div>

            {# ── Rôles personnalisés ── #}
            <div class="config-section config-section-full">
                <div class="config-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    Profils utilisateurs personnalisés
                </div>
                <div style="font-size:12px;color:var(--text-secondary);margin-bottom:14px;line-height:1.6;">
                    Créez des profils basés sur les rôles existants avec des permissions spécifiques.
                </div>

                {# Liste existante #}
                <template x-for="(role, idx) in uiConfig.customRoles" :key="role.id">
                    <div style="display:flex;align-items:flex-start;gap:12px;padding:12px 14px;background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:8px;">
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:13px;font-weight:600;margin-bottom:4px;" x-text="role.name"></div>
                            <div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;">
                                Basé sur <span class="user-role-badge" :class="'role-' + role.baseRole"
                                    x-text="roleLabel(role.baseRole)"
                                    style="font-size:10px;padding:2px 6px;"></span>
                                &nbsp;·&nbsp; ID : <code style="font-family:monospace;" x-text="role.baseRole + ':' + role.id"></code>
                            </div>
                            <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:4px;">
                                <template x-for="f in allFeatures" :key="f.id">
                                    <span style="font-size:10px;padding:2px 7px;border-radius:3px;"
                                        :style="role.features && role.features[f.id] ? 'background:rgba(201,168,76,.15);color:var(--gold);border:1px solid rgba(201,168,76,.3)' : 'background:var(--bg-base);color:var(--text-muted);border:1px solid var(--border)'">
                                        <span x-text="role.features && role.features[f.id] ? '✓' : '✗'"></span>
                                        <span x-text="f.label"></span>
                                    </span>
                                </template>
                            </div>
                            <div style="display:flex;flex-wrap:wrap;gap:4px;">
                                <template x-for="g in actionGroups" :key="g.name">
                                    <template x-for="a in g.actions" :key="a.id">
                                        <span x-show="role.actions && role.actions.includes(a.id)"
                                            style="font-size:10px;padding:2px 7px;border-radius:3px;background:rgba(107,163,247,.12);color:#6ba3f7;border:1px solid rgba(107,163,247,.25);"
                                            x-text="a.label"></span>
                                    </template>
                                </template>
                            </div>
                        </div>
                        <div style="display:flex;gap:6px;flex-shrink:0;">
                            <button class="btn-ghost" style="font-size:11px;padding:4px 10px;" @click="editCustomRole(role)">Modifier</button>
                            <button class="btn-ghost" style="font-size:11px;padding:4px 10px;color:var(--red-light);border-color:var(--red-light);"
                                @click="removeCustomRole(idx)">Suppr.</button>
                        </div>
                    </div>
                </template>

                {# Formulaire création/édition #}
                <div style="border:1px solid var(--border);border-radius:var(--radius-sm);padding:16px;background:var(--bg-elevated);margin-top:12px;">
                    <div style="font-size:12px;font-weight:700;color:var(--text-primary);margin-bottom:12px;"
                        x-text="editingRole ? 'Modifier le profil' : 'Créer un nouveau profil'"></div>
                    <div class="form-grid" style="margin-bottom:14px;">
                        <div class="form-group" style="margin:0;">
                            <label>Nom du profil *</label>
                            <input type="text" x-model="customRoleForm.name" placeholder="Ex: Chef de section">
                        </div>
                        <div class="form-group" style="margin:0;">
                            <label>Rôle de base *</label>
                            <select x-model="customRoleForm.baseRole">
                                <option value="lecteur">Lecteur</option>
                                <option value="gestionnaire">Gestionnaire</option>
                                <option value="superviseur_crise">Superviseur Crise</option>
                            </select>
                        </div>
                    </div>
                    <div style="margin-bottom:14px;">
                        <div style="font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text-muted);margin-bottom:8px;">Fonctionnalités visibles</div>
                        <div style="display:flex;gap:16px;flex-wrap:wrap;">
                            <template x-for="f in allFeatures" :key="f.id">
                                <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;">
                                    <input type="checkbox"
                                        :checked="!!(customRoleForm.features && customRoleForm.features[f.id])"
                                        @change="customRoleForm.features = {...(customRoleForm.features||{}), [f.id]: $event.target.checked}"
                                        style="accent-color:var(--gold);width:14px;height:14px;">
                                    <span x-text="f.label"></span>
                                </label>
                            </template>
                        </div>
                    </div>
                    <div style="margin-bottom:16px;">
                        <div style="font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text-muted);margin-bottom:8px;">Actions autorisées</div>
                        <template x-for="group in actionGroups" :key="group.name">
                            <div style="margin-bottom:10px;">
                                <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;" x-text="group.name"></div>
                                <div style="display:flex;gap:16px;flex-wrap:wrap;">
                                    <template x-for="a in group.actions" :key="a.id">
                                        <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;">
                                            <input type="checkbox"
                                                :checked="customRoleForm.actions && customRoleForm.actions.includes(a.id)"
                                                @change="customRoleForm.actions = $event.target.checked ? [...(customRoleForm.actions||[]), a.id] : (customRoleForm.actions||[]).filter(x => x !== a.id)"
                                                style="accent-color:var(--gold);width:14px;height:14px;">
                                            <span x-text="a.label"></span>
                                        </label>
                                    </template>
                                </div>
                            </div>
                        </template>
                    </div>
                    <div x-show="customRoleError" class="alert-error" x-text="customRoleError" style="margin-bottom:8px;"></div>
                    <div style="display:flex;gap:8px;">
                        <button class="btn-primary" @click="saveCustomRole()">
                            <span x-text="editingRole ? 'Mettre à jour' : 'Créer le profil'"></span>
                        </button>
                        <button x-show="editingRole" class="btn-ghost" @click="cancelEditRole()">Annuler</button>
                    </div>
                </div>
            </div>

            {# ── Administrateurs système ── #}
            {% if permissions.isSysAdmin %}
            <div class="config-section config-section-full">
                <div class="config-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    Administrateurs système
                </div>
                <div style="font-size:12px;color:var(--text-secondary);margin-bottom:14px;line-height:1.6;">
                    Comptes réservés à l'administration technique de l'application.
                </div>

                {# Liste admins #}
                <div style="margin-bottom:18px;overflow:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Identifiant</th>
                                <th>Créé le</th>
                                <th class="th-actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr x-show="sysAdmins.length === 0">
                                <td colspan="3" class="empty-state">Aucun admin système</td>
                            </tr>
                            <template x-for="admin in sysAdmins" :key="admin.id">
                                <tr>
                                    <td style="font-family:var(--font-display);font-weight:700;">
                                        <span x-text="admin.username"></span>
                                        <span x-show="admin.username === 'Sic'"
                                            style="margin-left:8px;font-size:10px;padding:2px 6px;border-radius:3px;background:rgba(201,168,76,.15);color:var(--gold);border:1px solid rgba(201,168,76,.3);">Compte initial</span>
                                    </td>
                                    <td style="color:var(--text-muted);font-size:12px;"
                                        x-text="new Date(admin.created_at).toLocaleDateString('fr-FR')"></td>
                                    <td class="td-actions">
                                        <button class="btn-ghost" style="font-size:11px;padding:4px 10px;"
                                            @click="openResetPassword(admin)">Réinit. MDP</button>
                                        <button class="btn-icon" style="color:var(--red-light);"
                                            x-show="admin.username !== 'Sic'"
                                            @click="deleteSysAdmin(admin)">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>

                {# Formulaire création / réinit MDP #}
                <div style="border:1px solid var(--border);border-radius:var(--radius-sm);padding:16px;background:var(--bg-elevated);">
                    <div style="font-size:12px;font-weight:700;color:var(--text-primary);margin-bottom:12px;"
                        x-text="resetTarget ? 'Réinitialiser le mot de passe de ' + resetTarget.username : 'Créer un nouvel administrateur système'"></div>
                    <div class="form-grid">
                        <div class="form-group" x-show="!resetTarget">
                            <label>Identifiant *</label>
                            <input type="text" x-model="newAdmin.username" placeholder="Ex: AdminTech" autocomplete="off">
                        </div>
                        <div class="form-group">
                            <label x-text="resetTarget ? 'Nouveau mot de passe * (8 car. min.)' : 'Mot de passe * (8 car. min.)'"></label>
                            <input type="password" x-model="newAdmin.password" placeholder="••••••••" autocomplete="new-password">
                        </div>
                    </div>
                    <div x-show="adminError" class="alert-error" x-text="adminError" style="margin-bottom:8px;"></div>
                    <div style="display:flex;gap:8px;">
                        <button class="btn-primary"
                            :disabled="!newAdmin.password || newAdmin.password.length < 8 || (!resetTarget && !newAdmin.username)"
                            @click="createSysAdmin()">
                            <span x-text="resetTarget ? 'Réinitialiser' : 'Créer'"></span>
                        </button>
                        <button x-show="resetTarget" class="btn-ghost" @click="cancelResetPassword()">Annuler</button>
                    </div>
                </div>
            </div>
            {% endif %}

            {# ── Comptes verrouillés ── #}
            {% if permissions.canAdmin %}
            <div class="config-section config-section-full">
                <div class="config-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    Comptes verrouillés
                </div>
                <div style="font-size:12px;color:var(--text-secondary);margin-bottom:14px;line-height:1.6;">
                    Comptes bloqués après 3 tentatives de connexion incorrectes. Le déblocage est manuel.
                </div>
                <div style="overflow:auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Identifiant</th>
                                <th>Tentatives</th>
                                <th>Verrouillé le</th>
                                <th class="th-actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr x-show="lockedUsers.length === 0">
                                <td colspan="4" class="empty-state">Aucun compte verrouillé</td>
                            </tr>
                            <template x-for="u in lockedUsers" :key="u.identifier">
                                <tr>
                                    <td style="font-family:var(--font-display);font-weight:700;" x-text="u.identifier"></td>
                                    <td>
                                        <span style="font-size:11px;padding:2px 7px;border-radius:3px;background:rgba(192,57,43,.12);color:var(--red-light);border:1px solid rgba(192,57,43,.25);"
                                            x-text="u.attempts + ' tentative' + (u.attempts > 1 ? 's' : '')"></span>
                                    </td>
                                    <td style="color:var(--text-muted);font-size:12px;"
                                        x-text="new Date(u.locked_at).toLocaleString('fr-FR')"></td>
                                    <td class="td-actions">
                                        <button class="btn-ghost" style="font-size:11px;padding:4px 10px;color:#6ec38a;border-color:#6ec38a;"
                                            @click="unlockUser(u.identifier)">
                                            <i class="fa-solid fa-lock-open"></i> Débloquer
                                        </button>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
                <button class="btn-ghost" style="margin-top:10px;font-size:11px;" @click="loadLockedUsers()">
                    <i class="fa-solid fa-rotate"></i> Actualiser
                </button>
            </div>
            {% endif %}

            {# ── Informations ── #}
            <div class="config-section">
                <div class="config-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    Informations
                </div>
                <div style="font-size:12px;color:var(--text-secondary);line-height:1.8;">
                    <p>• La configuration est stockée en base de données sécurisée.</p>
                    <p>• Elle est <strong>partagée automatiquement</strong> avec tous les utilisateurs dès la sauvegarde.</p>
                    <p>• Seul un <strong>administrateur</strong> peut modifier la configuration.</p>
                    <p>• Le bot doit être <strong>administrateur</strong> des salons pour inviter/expulser des membres.</p>
                    <p style="color:var(--text-muted);margin-top:8px;">
                        Token actuel :
                        <span :style="{ color: tchapConfig.enabled ? '#6ec38a' : 'var(--red-light)' }"
                            x-text="tchapConfig.enabled ? '✓ Configuré' : '✗ Non configuré'"></span>
                    </p>
                </div>
            </div>

        </div>
    </div>

    {# ── Modal reset password admin système ── #}
    <div class="modal-overlay" x-show="resetPasswordModal" x-cloak @click.self="resetPasswordModal = false">
        <div class="modal modal-sm">
            <div class="modal-header">
                <h3><i class="fa-solid fa-key"></i> Réinitialiser le mot de passe</h3>
                <button class="btn-icon" @click="resetPasswordModal = false"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <p style="font-size:13px;color:var(--text-secondary);margin-bottom:12px;">
                    Admin : <strong style="color:var(--text-primary);" x-text="resetTarget ? resetTarget.username : ''"></strong>
                </p>
                <div class="form-group">
                    <label>Nouveau mot de passe</label>
                    <input type="password" x-model="newAdmin.password">
                </div>
                <div x-show="adminError" class="alert-error" x-text="adminError" style="margin-top:10px;"></div>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" @click="cancelResetPassword()">Annuler</button>
                <button class="btn-primary" :disabled="!newAdmin.password || newAdmin.password.length < 8" @click="createSysAdmin()">
                    Modifier
                </button>
            </div>
        </div>
    </div>

</div>
{% endblock %}
