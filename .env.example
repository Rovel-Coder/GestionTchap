APP_ENV=prod
APP_SECRET=changeme-generate-with-openssl-rand-base64-32

# Mot de passe PostgreSQL — remplacer "changeme" ici ET dans DATABASE_URL ci-dessous
DB_PASSWORD=changeme

# Format : postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# ⚠ Remplacer "changeme" par la même valeur que DB_PASSWORD
DATABASE_URL=postgresql://tchap:changeme@postgres:5432/gestion_tchap

# Service bridge Tchap (tchap-service/) — laisser vide pour mode direct sans E2EE
# URL locale du microservice Node.js (même réseau Docker)
TCHAP_SERVICE_URL=http://tchap-bridge:3000
# Clé API partagée avec tchap-service (même valeur que API_KEY dans le bridge)
TCHAP_SERVICE_KEY=changeme-generate-with-openssl-rand-hex-32

# URL publique de l'application (utilisée par Symfony pour les URLs absolues)
DEFAULT_URI=https://votre-domaine.fr
