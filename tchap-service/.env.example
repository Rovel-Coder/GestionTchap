# Port d'écoute du service (accès local uniquement — ne pas exposer sur Internet)
PORT=3000

# Clé API partagée avec PHP — générer avec : openssl rand -hex 32
API_KEY=changeme-generate-with-openssl-rand-hex-32

# Credentials du bot Tchap
# Ces valeurs peuvent aussi être configurées via POST /login depuis l'interface PHP.
# Si data/bot-config.json existe, il a priorité sur ces variables.
TCHAP_HOMESERVER=https://matrix.agent.interieur.tchap.gouv.fr
TCHAP_ACCESS_TOKEN=
